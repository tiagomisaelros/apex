        btnC.style.background = 'var(--surface2)';
        btnC.style.color = '#ff4d6d';
        btnC.style.border = '1px solid rgba(255,77,109,0.4)';
      }
    } else {
      salEl.style.color = 'var(--green)';
      salEl.textContent = `${WALL.credits} créditos disponíveis`;
      // Restaura o botão ao estado normal
      const btnC = document.getElementById('btn-create');
      if (btnC) {
        btnC.style.background = '';
        btnC.style.color = '';
        btnC.style.border = '';
        btnC.disabled = false;
        btnC.innerHTML = '⚡ Gerar Vídeo 3D com IA';
        btnC.onclick = startPipeline;
      }
    }
  }

    // ── MODERAÇÃO ANTECIPADA via Gemini Flash ──
    try {
      const { data: { session } } = await sb.auth.getSession();
      const token = session?.access_token;
      if (!token) throw new Error('Sessão expirada');

      // Chama Edge Function de moderação com timeout de 15s
      const modController = new AbortController();
      const modTimeout = setTimeout(() => modController.abort(), 15000);

      let modRes, modData;
      try {
        modRes = await fetch(`${SUPABASE_FUNCTIONS_URL}/ai-moderate`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({
            mode: 'preflight',
            image_base64: CURRENT_FILE_BASE64,
            image_mime: f.type || 'image/jpeg',
          }),
          signal: modController.signal,
        });
        clearTimeout(modTimeout);
        modData = await modRes.json();
      } catch(fetchErr) {
        clearTimeout(modTimeout);
        throw new Error(fetchErr.name === 'AbortError' ? 'Timeout na moderação (>15s)' : fetchErr.message);
      }
      const score    = modData.score    ?? 75;
      const approved = modData.approved ?? true;
      const result   = modData.result   ?? {};

      // Montar tags de resultado
      const tags = [];
      if (approved) {
        tags.push(`<span class="tag tg">✓ Conteúdo Seguro</span>`);
        tags.push(`<span class="tag tb">Score: ${score}/100</span>`);
        if (result.has_logo)  tags.push(`<span class="tag to">Logo Detectado</span>`);
        if (result.has_text)  tags.push(`<span class="tag tpur">Texto Detectado</span>`);
        if (result.brand_detected) tags.push(`<span class="tag tgold">🏷️ ${result.brand_detected}</span>`);
        if (result.quality_score) tags.push(`<span class="tag tb">Qualidade: ${result.quality_score}/100</span>`);

        document.getElementById('ai-tags').innerHTML = tags.join('');
        document.getElementById('ai-text').textContent =
          `Imagem aprovada para geração. ` +
          (result.suggestions?.length ? `Sugestões: ${result.suggestions.join('; ')}` : 'Pronta para o pipeline de IA.');

        // Libera o botão de geração
        document.getElementById('btn-create').disabled = false;
        document.getElementById('btn-create').innerHTML = '⚡ Gerar Vídeo 3D com IA';
        notif(`Imagem aprovada! Score Gemini: ${score}/100`, '✅');

      } else {
        // ── BLOQUEIO IMEDIATO ──
        const reason = result.rejection_reason || 'Conteúdo inadequado detectado';
        const flags  = Object.entries(result.categories || {})
          .filter(([,v]) => v)
          .map(([k]) => k.replace(/_/g,' '));

        tags.push(`<span class="tag tr">✗ Reprovado</span>`);
        tags.push(`<span class="tag tr">Score: ${score}/100</span>`);
        flags.forEach(f2 => tags.push(`<span class="tag tr">⚠️ ${f2}</span>`));

        document.getElementById('ai-tags').innerHTML = tags.join('');
        document.getElementById('ai-text').textContent = `Bloqueado: ${reason}`;

        // Limpa imagem e bloqueia
        SEL_FILE = null;
        CURRENT_FILE_BASE64 = null;

        setTimeout(() => {
          clearImage();
          document.getElementById('btn-create').disabled = false;
          document.getElementById('btn-create').innerHTML = '⚡ Gerar Vídeo 3D com IA';
        }, 3000);

        notif(`Imagem bloqueada pelo Gemini: ${reason}`, '🚫');
        return;
      }

    } catch(err) {
      console.warn('Pré-moderação falhou:', err.message);
      // Sempre libera o botão — nunca fica travado
      document.getElementById('ai-tags').innerHTML =
        '<span class="tag tgold">⚠️ Verificação offline</span>' +
        '<span class="tag to">Moderação no pipeline</span>';
      document.getElementById('ai-text').textContent =
        'Verificação prévia indisponível (' + err.message + '). Moderação completa será feita durante a geração.';
      document.getElementById('btn-create').disabled = false;
      document.getElementById('btn-create').innerHTML = '⚡ Gerar Vídeo 3D com IA';
      notif('Gemini offline — você pode continuar normalmente', '⚠️');
    }
  };
  reader.readAsDataURL(f);
}

