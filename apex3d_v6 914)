let currentGradeTab = 'engagement';

function gradeContentTab(type) {
  currentGradeTab = type;
  ['engagement','news','emergency'].forEach(t => {
    const btn = document.getElementById('gc-tab-'+t);
    if (btn) {
      btn.style.color = t === type ? 'var(--accent)' : 'var(--muted)';
      btn.style.borderBottom = t === type ? '2px solid var(--accent)' : '2px solid transparent';
      btn.style.fontWeight = t === type ? '700' : '400';
    }
  });
  loadAdminContent(type);
}

async function loadAdminContent(type) {
  type = type || currentGradeTab;
  const list = document.getElementById('adm-content-list');
  if (!list) return;
  list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--dim)"><div class="spin" style="margin:0 auto 10px"></div>Carregando...</div>';

  let items, error;
  try {
    const res = await sb.from('admin_content')
      .select('*')
      .eq('content_type', type)
      .order('priority', { ascending: true });
    items = res.data;
    error = res.error;
  } catch(e) {
    console.error('loadAdminContent erro:', e);
    list.innerHTML = `<div style="text-align:center;padding:30px;color:#ff4444">Erro: ${e.message}</div>`;
    return;
  }
  if (error) {
    console.error('loadAdminContent error:', error);
    list.innerHTML = `<div style="text-align:center;padding:30px;color:#ff4444">Erro ao carregar: ${error.message}</div>`;
    return;
  }

  if (!items?.length) {
    const typeLabel = { engagement:'institucional/engajamento', news:'notícia', emergency:'emergência' };
    list.innerHTML = `<div style="text-align:center;padding:40px;color:var(--dim)">
      <div style="font-size:32px;margin-bottom:8px">${type==='engagement'?'🎬':type==='news'?'📰':'🚨'}</div>
      Nenhum conteúdo de ${typeLabel[type]||type} cadastrado
      <br><button class="btn btn-p btn-sm" style="margin-top:14px" onclick="openAdminContentModal('${type}')">+ Adicionar agora</button>
    </div>`;
    return;
  }

  const typeColors = { engagement:'var(--accent)', news:'#3a86ff', emergency:'#ff4444' };
  list.innerHTML = items.map(item => `
    <div class="card" style="margin-bottom:10px;padding:14px">
      <div style="display:flex;align-items:start;gap:12px">
        <video src="${item.video_url}" style="width:80px;height:50px;object-fit:cover;border-radius:6px;background:#000;flex-shrink:0" muted></video>
        <div style="flex:1;min-width:0">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
            <span style="font-weight:700;font-size:14px">${item.title}</span>
            <span class="tag" style="background:${typeColors[item.content_type]||'var(--muted)'}20;color:${typeColors[item.content_type]||'var(--muted)'};font-size:10px">${item.content_type}</span>
            ${item.is_active ? '<span class="tag tg" style="font-size:10px">● Ativo</span>' : '<span class="tag" style="font-size:10px;background:var(--surface2);color:var(--muted)">● Inativo</span>'}
            ${item.emergency_mode ? '<span class="tag" style="background:#ff444420;color:#ff4444;font-size:10px">🚨 Emergência</span>' : ''}
          </div>
          <div style="font-size:11px;color:var(--muted)">
            Prioridade: ${item.priority} &nbsp;|&nbsp; Duração: ${item.duration_seconds}s
            ${item.starts_at ? ` &nbsp;|&nbsp; De: ${new Date(item.starts_at).toLocaleString('pt-BR')}` : ''}
            ${item.ends_at ? ` até ${new Date(item.ends_at).toLocaleString('pt-BR')}` : ''}
            ${!item.starts_at && !item.ends_at ? ' &nbsp;|&nbsp; Sempre ativo' : ''}
          </div>
        </div>
        <div style="display:flex;gap:6px;flex-shrink:0">
          <button class="btn btn-g btn-sm" onclick="toggleAdminContent('${item.id}',${!item.is_active})">${item.is_active ? 'Desativar' : 'Ativar'}</button>
          ${item.emergency_mode 
            ? `<button class="btn btn-sm" style="background:#ff444420;color:#ff4444" onclick="toggleEmergencyContent('${item.id}',false)">Desativar Emerg.</button>`
            : `<button class="btn btn-sm" style="background:var(--surface2);color:var(--muted)" onclick="toggleEmergencyContent('${item.id}',true)">Emerg.</button>`
          }
          <button class="btn btn-sm" style="background:#ff444415;color:#ff4444" onclick="deleteAdminContent('${item.id}')">✕</button>
        </div>
      </div>
    </div>
  `).join('');
}

async function checkEmergencyStatus() {
  const { data } = await sb.from('admin_content')
    .select('id')
    .eq('emergency_mode', true)
    .eq('is_active', true)
    .limit(1);
  
  const active = data?.length > 0;
  const btn = document.getElementById('btn-emergency');
  const info = document.getElementById('emergency-active-info');
  if (btn) {
    btn.textContent = active ? '✓ Emergência Ativa' : 'Ativar Emergência';
    btn.style.background = active ? '#ff6600' : '#ff4444';
  }
  if (info) info.style.display = active ? 'block' : 'none';
}

async function toggleEmergency() {
  const { data } = await sb.from('admin_content')
    .select('id, is_active')
    .eq('emergency_mode', true)
    .limit(1);
  
  if (data?.length > 0) {
    // Tem emergência ativa — desativa
    const { error } = await sb.from('admin_content')
      .update({ is_active: false })
      .eq('emergency_mode', true);
    if (!error) { notif('Emergência desativada','✅'); checkEmergencyStatus(); loadAdminContent(currentGradeTab); }
  } else {
    // Não tem — abre modal para criar/ativar
    openAdminContentModal('emergency');
  }
}

async function toggleAdminContent(id, activate) {
  const { error } = await sb.from('admin_content').update({ is_active: activate }).eq('id', id);
  if (!error) { notif(activate ? 'Conteúdo ativado' : 'Conteúdo desativado','✅'); loadAdminContent(currentGradeTab); checkEmergencyStatus(); }
  else notif('Erro: '+error.message,'❌');
}

async function toggleEmergencyContent(id, activate) {
  if (activate) {
    if (!confirm('Ativar modo emergência? Isso interromperá TODAS as telas imediatamente.')) return;
    // Desativa outros emergency ativos primeiro
    await sb.from('admin_content').update({ emergency_mode: false }).eq('emergency_mode', true);
  }
  const { error } = await sb.from('admin_content')
    .update({ emergency_mode: activate, is_active: activate ? true : false, content_type: 'emergency' })
    .eq('id', id);
  if (!error) { notif(activate ? '🚨 Emergência ATIVADA em todas as telas!' : 'Emergência desativada','✅'); loadAdminContent(currentGradeTab); checkEmergencyStatus(); }
  else notif('Erro: '+error.message,'❌');
}

async function deleteAdminContent(id) {
  if (!confirm('Remover este conteúdo da grade?')) return;
  const { error } = await sb.from('admin_content').delete().eq('id', id);
  if (!error) { notif('Conteúdo removido','✅'); loadAdminContent(currentGradeTab); }
  else notif('Erro: '+error.message,'❌');
}

let adminContentModalType = 'engagement';
function openAdminContentModal(type) {
  adminContentModalType = type;
  const typeLabel = { engagement:'Institucional/Engajamento', news:'Notícia', emergency:'Emergência' };
  document.getElementById('acm-title').textContent = '+ ' + (typeLabel[type]||type);
  document.getElementById('acm-type').value = type;
  document.getElementById('acm-emergency-flag').checked = type === 'emergency';
  document.getElementById('acm-priority').value = type === 'emergency' ? '1' : type === 'news' ? '2' : '3';
  document.getElementById('acm-title-input').value = '';
  document.getElementById('acm-video-url').value = '';
  document.getElementById('acm-duration').value = '15';
  document.getElementById('acm-starts').value = '';
  document.getElementById('acm-ends').value = '';
  openModal('m-admin-content');
}

async function saveAdminContent() {
  const title    = document.getElementById('acm-title-input').value.trim();
  const videoUrl = document.getElementById('acm-video-url').value.trim();
  const type     = document.getElementById('acm-type').value;
  const priority = parseInt(document.getElementById('acm-priority').value) || 2;
  const duration = parseInt(document.getElementById('acm-duration').value) || 15;
  const starts   = document.getElementById('acm-starts').value;
  const ends     = document.getElementById('acm-ends').value;
  const isEmerg  = document.getElementById('acm-emergency-flag').checked;

  if (!title)    { notif('Informe o título','⚠️'); return; }
  if (!videoUrl) { notif('Informe a URL do vídeo','⚠️'); return; }
  if (!videoUrl.startsWith('http')) { notif('URL deve começar com https://','⚠️'); return; }

  const payload = {
    title, video_url: videoUrl, content_type: type,
    priority, duration_seconds: duration,
    is_active: true, emergency_mode: isEmerg,
    created_by: ME.id,
    starts_at: starts ? new Date(starts).toISOString() : null,
    ends_at:   ends   ? new Date(ends).toISOString()   : null,
  };

  if (isEmerg) {
    // Desativa emergências anteriores
    await sb.from('admin_content').update({ emergency_mode: false, is_active: false }).eq('emergency_mode', true);
  }

  const { error } = await sb.from('admin_content').insert(payload);
  if (error) { notif('Erro: '+error.message,'❌'); return; }

  closeModal('m-admin-content');
  notif(isEmerg ? '🚨 Emergência ativada em todas as telas!' : 'Conteúdo adicionado à grade!','✅');
  loadAdminContent(type);
  checkEmergencyStatus();
  gradeContentTab(type);
}


function previewAdminVideo() {
  const url = document.getElementById('acm-video-url')?.value?.trim();
  const preview = document.getElementById('acm-preview');
  if (!preview) return;
  if (url && url.startsWith('http')) {
    preview.src = url;
    preview.style.display = 'block';
  } else {
    preview.style.display = 'none';
  }
}

