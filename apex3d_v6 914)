<script>
// ── ADMIN: TABS ──────────────────────────────────────────────────────────
function admTab(tab) {
  ['users','networks','system','grade'].forEach(t => {
    const btn  = document.getElementById('adm-tab-'+t);
    const pane = document.getElementById('adm-pane-'+t);
    const active = t === tab;
    if (btn)  { btn.style.color = active ? 'var(--accent)' : 'var(--muted)'; btn.style.borderBottom = active ? '2px solid var(--accent)' : '2px solid transparent'; btn.style.fontWeight = active ? '700' : '600'; }
    if (pane) pane.style.display = active ? 'block' : 'none';
  });
  if (tab === 'networks') loadAdminNetworks();
  if (tab === 'grade') { initGradeConfigDevices(); loadAdminContent(); checkEmergencyStatus(); }
}

async function loadAdminNetworks() {
  const list = document.getElementById('adm-networks-list');
  if (!list) return;
  list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--dim)"><div class="spin" style="margin:0 auto 12px"></div>Carregando...</div>';

  const { data: networks } = await sb.from('enterprise_networks')
    .select('*')
    .order('created_at', { ascending: false });

  if (!networks?.length) {
    list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--dim)"><div style="font-size:32px;margin-bottom:8px">🏢</div>Nenhuma rede cadastrada ainda</div>';
    return;
  }

  const planLabel = { starter:'🚀 Starter', pro:'⭐ Pro', enterprise:'💎 Enterprise' };
  const planColor = { starter:'#ff6b2b', pro:'#ffd166', enterprise:'#00ff88' };

  list.innerHTML = networks.map(n => `
    <div style="padding:14px;border:1px solid var(--border);border-radius:12px;margin-bottom:10px;cursor:pointer" onclick="openManageNetworkModal('${n.id}')" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div style="display:flex;align-items:center;gap:12px">
          <div style="width:36px;height:36px;border-radius:8px;background:${n.primary_color||'#ff6b2b'}33;border:1px solid ${n.primary_color||'#ff6b2b'}44;display:flex;align-items:center;justify-content:center;font-size:16px">🏢</div>
          <div>
            <div style="font-size:13px;font-weight:700;color:var(--text)">${n.name}</div>
            <div style="font-size:11px;color:var(--dim)">${n.owner_id?.slice(0,8) || 'Sem owner'}</div>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px">
          <span style="padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;background:${planColor[n.plan]||'#ff6b2b'}22;color:${planColor[n.plan]||'#ff6b2b'};border:1px solid ${planColor[n.plan]||'#ff6b2b'}44">${planLabel[n.plan]||n.plan}</span>
          <span style="font-size:11px;color:var(--dim)">${new Date(n.created_at).toLocaleDateString('pt-BR')}</span>
        </div>
      </div>
    </div>`).join('');
}

function openCreateNetworkModal() {
  document.getElementById('cn-name').value = '';
  document.getElementById('cn-email').value = '';
  document.getElementById('cn-notes').value = '';
  document.getElementById('cn-err').classList.remove('show');
  document.getElementById('cn-ok').classList.remove('show');
  openModal('m-create-network');
}

async function doCreateNetwork() {
  const name  = document.getElementById('cn-name').value.trim();
  const plan  = document.getElementById('cn-plan').value;
  const color = document.getElementById('cn-color').value;
  const email = document.getElementById('cn-email').value.trim();
  const notes = document.getElementById('cn-notes').value.trim();
  const btn   = document.getElementById('btn-create-network');
  const err   = document.getElementById('cn-err');
  const ok    = document.getElementById('cn-ok');

  if (!name) { showErr(err, 'Nome da rede é obrigatório'); return; }

  btn.disabled = true; btn.innerHTML = '<div class="spin"></div> Criando...';
  err.classList.remove('show');

  try {
    // Find owner by email if provided
    let ownerId = ME.id;
    if (email) {
      const { data: ownerProf } = await sb.from('profiles').select('id').eq('email', email).maybeSingle();
      if (ownerProf) ownerId = ownerProf.id;
    }

    // Gera slug a partir do nome (ex: "Grupo Mídia SP" → "grupo-midia-sp")
    const slug = name.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
      + '-' + Date.now().toString(36);

    const { data: network, error: netErr } = await sb.from('enterprise_networks').insert({
      name, slug, plan, primary_color: color, owner_id: ownerId,
      admin_notes: notes || null, active: true
    }).select().single();

    if (netErr) throw new Error(netErr.message);

    // Auto-add owner as enterprise_admin member
    await sb.from('enterprise_members').insert({
      network_id: network.id, user_id: ownerId, role: 'enterprise_admin', status: 'active'
    });

    // Update owner role in profiles
    await sb.from('profiles').update({ role: 'enterprise_admin', network_id: network.id }).eq('id', ownerId);

    ok.textContent = `✅ Rede "${name}" criada com sucesso!`;
    ok.classList.add('show');
    setTimeout(() => { closeModal('m-create-network'); loadAdminNetworks(); }, 1500);
  } catch(e) {
    showErr(err, e.message);
  } finally {
    btn.disabled = false; btn.innerHTML = 'Criar Rede Enterprise';
  }
}

async function openManageNetworkModal(networkId) {
  openModal('m-manage-network');
  const body = document.getElementById('mn-body');
  body.innerHTML = '<div style="text-align:center;padding:40px"><div class="spin" style="margin:0 auto"></div></div>';

  const { data: n } = await sb.from('enterprise_networks')
    .select('*')
    .eq('id', networkId).single();

  if (!n) { body.innerHTML = '<div style="color:var(--dim)">Rede não encontrada.</div>'; return; }

  document.getElementById('mn-title').textContent = `🏢 ${n.name}`;

  const planLabel = { starter:'🚀 Starter', pro:'⭐ Pro', enterprise:'💎 Enterprise' };

  body.innerHTML = `
    <div style="display:grid;gap:14px">
      <div class="fg"><label class="fl">Nome da rede</label><input class="fi" id="mn-name" value="${n.name}"></div>
      <div class="fg"><label class="fl">Plano</label>
        <select class="fi" id="mn-plan">
          <option value="starter" ${n.plan==='starter'?'selected':''}>🚀 Starter — R$2.990/mês</option>
          <option value="pro" ${n.plan==='pro'?'selected':''}>⭐ Pro — R$8.990/mês</option>
          <option value="enterprise" ${n.plan==='enterprise'?'selected':''}>💎 Enterprise — Sob consulta</option>
        </select>
      </div>
      <div class="fg"><label class="fl">Cor primária</label><input class="fi" id="mn-color" type="color" value="${n.primary_color||'#ff6b2b'}" style="height:42px;cursor:pointer"></div>
      <div style="background:var(--surface2);border-radius:10px;padding:12px;font-size:12px;color:var(--muted)">
        <div>👤 Owner ID: <span style="font-family:'DM Mono',monospace;font-size:10px">${n.owner_id}</span></div>
        <div style="margin-top:4px">📅 Criada em: ${new Date(n.created_at).toLocaleDateString('pt-BR')}</div>
        <div style="margin-top:4px">🔑 ID: <span style="font-family:'DM Mono',monospace;font-size:10px">${n.id}</span></div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-g" style="flex:1" onclick="closeModal('m-manage-network')">Cancelar</button>
        <button class="btn btn-p" style="flex:2" onclick="saveNetworkChanges('${n.id}')">💾 Salvar alterações</button>
      </div>
      <div class="msg-err" id="mn-err"></div>
      <div class="msg-ok" id="mn-ok"></div>
    </div>`;
}

async function saveNetworkChanges(networkId) {
  const name  = document.getElementById('mn-name').value.trim();
  const plan  = document.getElementById('mn-plan').value;
  const color = document.getElementById('mn-color').value;
  const err   = document.getElementById('mn-err');
  const ok    = document.getElementById('mn-ok');

  if (!name) { showErr(err, 'Nome não pode ser vazio'); return; }

  const { error } = await sb.from('enterprise_networks')
    .update({ name, plan, primary_color: color })
    .eq('id', networkId);

  if (error) { showErr(err, error.message); return; }

  ok.textContent = '✅ Rede atualizada!';
  ok.classList.add('show');
  setTimeout(() => { closeModal('m-manage-network'); loadAdminNetworks(); }, 1200);
}

// ── ENTERPRISE: TABS ─────────────────────────────────────────────────────
function entTab(tab) {
  ['overview','members','approvals','report'].forEach(t => {
    const btn  = document.getElementById('ent-tab-'+t);
    const pane = document.getElementById('ent-pane-'+t);
    const active = t === tab;
    if (btn)  { btn.style.color = active ? 'var(--accent)' : 'var(--muted)'; btn.style.borderBottom = active ? '2px solid var(--accent)' : '2px solid transparent'; btn.style.fontWeight = active ? '700' : '600'; }
    if (pane) pane.style.display = active ? 'block' : 'none';
  });
  if (tab === 'members')   loadEntMembers();
  if (tab === 'approvals') loadEntApprovals();
  if (tab === 'report')    loadEntReport();
