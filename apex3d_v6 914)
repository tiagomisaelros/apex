    }
  }

  // Aprovações pendentes
  const appListEl = document.getElementById('ent-approvals-list');
  if (appListEl) {
    const approvals = approvalRes.data || [];
    if (!approvals.length) {
      appListEl.innerHTML = '<div style="text-align:center;padding:22px;color:var(--dim);font-size:13px">✅ Nenhuma aprovação pendente</div>';
    } else {
      appListEl.innerHTML = approvals.map(a => `
