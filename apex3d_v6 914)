    // Bloqueia o botão visualmente
    const btnC = document.getElementById('btn-create');
    btnC.disabled = true;
    btnC.innerHTML = '💳 Créditos insuficientes — Compre mais';
    btnC.style.background = 'var(--surface2)';
    btnC.style.color = '#ff4d6d';
    btnC.style.border = '1px solid #ff4d6d';
    btnC.onclick = () => go('wallet');
    // Notificação
    notif(`Saldo insuficiente. Você tem ${credits} créditos, precisa de 6. Clique em Carteira para comprar.`, '💳');
    // Shake animation na área de custo
    const costBox = btnC.closest('.card') || btnC.parentElement;
    if (costBox) {
      costBox.style.animation = 'shake 0.4s ease';
      setTimeout(() => costBox.style.animation = '', 500);
    }
    return;
  }

  const btn = document.getElementById('btn-create');
  btn.disabled = true;
  btn.innerHTML = '<div class="spin"></div> Iniciando...';

  document.getElementById('pipeline-status').style.display = 'block';
  document.getElementById('video-result').style.display = 'none';

  // Reset steps
  ['upload','flux','kling','gemini'].forEach(s => setPipelineStep(s,'wait',0));
  setPipelineStep('upload','active',30);

  try {
    // ── STEP 1: Upload imagem para Supabase Storage ──
    const { data: storageData, error: storageErr } = await sb.storage
      .from('campaign-assets')
      .upload(
        `originals/${ME.id}_${Date.now()}_${SEL_FILE.name}`,
        SEL_FILE,
        { contentType: SEL_FILE.type, upsert: false }
      );
    if (storageErr) throw new Error('Upload falhou: ' + storageErr.message);

    const { data: pubUrl } = sb.storage.from('campaign-assets').getPublicUrl(storageData.path);
    const imageUrl = pubUrl.publicUrl;
    setPipelineStep('upload','done',100);
    notif('Imagem enviada!','✅');

    // ── STEP 2: Gemini — Moderação ANTES de gastar créditos ──
    setPipelineStep('gemini','active',50);
    document.getElementById('pipeline-eta').textContent = '⏱️ Gemini moderando conteúdo... (~2s)';
    btn.innerHTML = '<div class="spin"></div> Moderando...';

    // Obter token robusto com refresh automático
    let _sess = (await sb.auth.getSession()).data?.session;
    if (!_sess?.access_token) _sess = (await sb.auth.refreshSession()).data?.session;
    if (!_sess?.access_token) throw new Error('Sessão expirada. Faça login novamente.');
    const token = _sess.access_token;

    const modRes = await fetch(`${SUPABASE_FUNCTIONS_URL}/ai-moderate`, {
      method: 'POST',
      headers: { 
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json',
        'apikey': SUPABASE_KEY,
      },
      body: JSON.stringify({ mode: 'preflight', image_base64: CURRENT_FILE_BASE64, image_mime: SEL_FILE.type }),
    });
    const modData = await modRes.json();

    if (modData.approved === false) {
      setPipelineStep('gemini','error',100);
      const reason = modData.result?.rejection_reason || 'Conteúdo inadequado';
      notif(`🚫 Imagem bloqueada: ${reason}`, '❌');
      btn.disabled = false; btn.innerHTML = '⚡ Gerar Vídeo 3D com IA';
      document.getElementById('pipeline-eta').textContent = `❌ Bloqueado: ${reason}`;
      return;
    }
    setPipelineStep('gemini','done',100);
    notif(`Conteúdo aprovado! Score: ${modData.score}/100`,'🛡️');

    // ── Criar campanha no banco ──
    // Valores de config da tela — usa defaults se campos estiverem ocultos (advertiser)
