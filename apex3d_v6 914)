async function openBookModal(screenId, screenName, pricePerSlot, slotsPerHour, ownerId = '') {
  BOOK_DEV = { id: screenId, name: screenName, price_per_slot: pricePerSlot, slots_per_hour: slotsPerHour, owner_id: ownerId };
  // Busca device_id vinculado a esta screen
  const { data: linkedDevice } = await sb.from('devices').select('id, owner_id').eq('screen_id', screenId).maybeSingle();
  if (linkedDevice) {
    BOOK_DEV.device_id = linkedDevice.id;
    BOOK_DEV.owner_id  = linkedDevice.owner_id || ownerId;
  } else {
    BOOK_DEV.device_id = null; // sem device vinculado ainda
  }
  document.getElementById('book-screen-name').textContent = '📺 ' + screenName;

  // Carregar campanhas aprovadas do usuário
  const { data: camps } = await sb.from('campaigns')
    .select('id, name')
    .eq('user_id', ME.id)
    .eq('status', 'approved')
    .order('created_at', { ascending: false });

  const sel = document.getElementById('book-campaign');
  if (!camps || camps.length === 0) {
    sel.innerHTML = '<option value="">Nenhuma campanha aprovada — crie e aprove primeiro</option>';
  } else {
    sel.innerHTML = '<option value="">Selecione uma campanha aprovada</option>' +
      camps.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
  }

  // Datas padrão: amanhã + 7 dias
  const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate()+1); tomorrow.setHours(8,0,0,0);
  const weekout  = new Date(tomorrow); weekout.setDate(weekout.getDate()+7);
  document.getElementById('book-start').value = tomorrow.toISOString().slice(0,16);
  document.getElementById('book-end').value   = weekout.toISOString().slice(0,16);

  updateBookCalc();
  document.getElementById('m-book').classList.add('show');
}

function updateBookCalc() {
  if (!BOOK_DEV) return;
  const start = new Date(document.getElementById('book-start').value);
  const end   = new Date(document.getElementById('book-end').value);
  if (!start || !end || end <= start) return;

  const hours    = (end - start) / 3600000;
  const days     = hours / 24;
  const subtotal = BOOK_DEV.price_per_slot ? (hours * BOOK_DEV.price_per_slot * 40) : (hours * 10); // fallback
  const fee      = subtotal * 0.15;
  const total    = subtotal + fee;

  const isAdmin = PROF?.role === 'super_admin';

  // Label e valores financeiros
  const subLabel = document.getElementById('bk-sub-label');
  if (subLabel) subLabel.textContent = isAdmin ? 'Subtotal' : 'Valor total';
  document.getElementById('bk-sub').textContent = isAdmin
    ? `R$${subtotal.toFixed(2)}`
    : `R$${total.toFixed(2)}`;
  const feeRow = document.getElementById('bk-fee-row');
  if (feeRow) {
    feeRow.style.display = isAdmin ? 'flex' : 'none';
    document.getElementById('bk-fee').textContent = `R$${fee.toFixed(2)}`;
  }
  const totalRow = document.getElementById('bk-total-row');
  if (totalRow) totalRow.style.display = isAdmin ? 'flex' : 'none';
  document.getElementById('bk-total').textContent = `R$${total.toFixed(2)}`;

  // ── Estimativa de exibições ──
  // Grade: bloco de 11 posições → 8 anunciante + 2 institucional + 1 notícia
  // Cada exibição = 15s → 240 blocos por hora → 1920 slots de anunciante/hora
  // Com fila cheia (40 anunciantes): mínimo = blocos_hora × 8 ÷ 40
  const BLOCK_SIZE       = 11;   // posições por bloco
  const ADV_PER_BLOCK    = 8;    // slots de anunciante por bloco
  const AVG_DUR_SEC      = 15;   // duração média por slot
  const MAX_ADVERTISERS  = 40;   // fila cheia

  // Blocos por hora (cada bloco dura AVG_DUR_SEC × BLOCK_SIZE segundos)
  const blocksPerHour  = 3600 / (AVG_DUR_SEC * BLOCK_SIZE);
  const totalBlocks    = blocksPerHour * hours;

  // Mínimo garantido: fila cheia (pior caso)
  const minExibicoes   = Math.floor((totalBlocks * ADV_PER_BLOCK) / MAX_ADVERTISERS);

  // Máximo esperado: só 1 anunciante na fila (melhor caso)
  const maxExibicoes   = Math.floor(totalBlocks * ADV_PER_BLOCK);

  // Frequência mínima: a cada quantos minutos aparece no pior caso
  const freqMinMin     = (hours * 60) / minExibicoes;
  const freqMaxMin     = (hours * 60) / maxExibicoes;

  document.getElementById('bk-est-min').textContent = minExibicoes.toLocaleString('pt-BR');
  document.getElementById('bk-est-max').textContent = maxExibicoes.toLocaleString('pt-BR');
  document.getElementById('bk-est-detail').innerHTML =
    `Período contratado: ${hours.toFixed(0)}h (${days.toFixed(1)} dias)`;

  document.getElementById('bk-estimate').style.display = 'block';
  document.getElementById('book-price-calc').style.display = 'block';
}

