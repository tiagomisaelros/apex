    const { data: camp, error: campErr } = await sb.from('campaigns').insert({
      user_id: ME.id,
      name,
      status: 'processing',
      original_image_url: imageUrl,
      physics_preset: PRESET,
      screen_height_m:   screenH,
      viewer_distance_m: screenD,
      screen_angle:      screenA,
      ai_model: 'kling-v1-5-pro',
      ai_provider: 'wavespeed',
      moderation_score: modData.score,
      moderation_result: modData.result,
