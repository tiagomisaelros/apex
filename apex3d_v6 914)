  // Carrega telas
  await loadEntScreens(screens);
}

async function loadEntScreens(preloaded) {
  const listEl = document.getElementById('ent-screens-list');
  if (!ENT_NETWORK || !listEl) return;

  const filterVal = document.getElementById('ent-branch-filter')?.value || 'all';

  let screens = preloaded;
  if (!screens) {
    const { data: entMems } = await sb.from('enterprise_members')
      .select('user_id').eq('network_id', ENT_NETWORK.id).eq('status', 'active');
    const entOwnerSet = new Set((entMems || []).map(m => m.user_id));
    if (ENT_NETWORK.owner_id) entOwnerSet.add(ENT_NETWORK.owner_id);
    const entMemberIds = [...entOwnerSet];
    if (!entMemberIds.length) {
      screens = [];
    } else {
      let q = sb.from('devices').select('*, enterprise_branches(name)').in('owner_id', entMemberIds);
      if (filterVal !== 'all') q = q.eq('branch_id', filterVal);
      const { data } = await q;
      screens = data || [];
    }
  }

  if (!screens.length) {
    listEl.innerHTML = '<div style="text-align:center;padding:22px;color:var(--dim);font-size:13px">Nenhuma tela vinculada à rede</div>';
    return;
  }

  const now = Date.now();
  listEl.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-top:4px">
      ${screens.map(s => {
        const lastHB = s.last_heartbeat ? new Date(s.last_heartbeat).getTime() : 0;
        const online = (now - lastHB) < 120000;
        return `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:14px">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
            <div style="font-size:13px;font-weight:600;color:var(--text)">${s.name}</div>
            <span style="width:8px;height:8px;border-radius:50%;background:${online?'#00ff88':'#ff4d6d'};margin-top:3px;flex-shrink:0"></span>
          </div>
          <div style="font-size:11px;color:var(--muted)">${s.location_city||''}${s.location_state?'/'+s.location_state:''}</div>
          ${s.enterprise_branches ? `<div style="font-size:11px;color:var(--dim);margin-top:4px">📍 ${s.enterprise_branches.name}</div>` : ''}
          <div style="font-size:11px;color:${online?'#00ff88':'var(--dim)'};margin-top:6px;font-weight:600">${online?'🟢 Online':'⚫ Offline'}</div>
        </div>`;
      }).join('')}
    </div>`;
}

async function reviewApproval(approvalId, status) {
  let reason = null;
  if (status === 'rejected') {
    reason = prompt('Motivo da rejeição:');
    if (!reason) return;
  }
  const { error } = await sb.from('enterprise_approvals')
    .update({ status, rejection_reason: reason, reviewed_by: ME.id })
    .eq('id', approvalId);
  if (error) { notif('Erro ao processar aprovação', '❌'); return; }
  notif(status === 'approved' ? 'Campanha aprovada!' : 'Campanha rejeitada', status === 'approved' ? '✅' : '❌');
  await loadEnterprise();
}

function openModalAddBranch() {
  document.getElementById('branch-name').value = '';
  document.getElementById('branch-city').value = '';
  document.getElementById('branch-state').value = '';
  openModal('m-branch');
}

async function saveBranch() {
  if (!ENT_NETWORK) return;
  const name  = document.getElementById('branch-name').value.trim();
  const city  = document.getElementById('branch-city').value.trim();
  const state = document.getElementById('branch-state').value.trim().toUpperCase();
  if (!name) { notif('Nome da filial é obrigatório', '⚠️'); return; }
  const { error } = await sb.from('enterprise_branches').insert({
    network_id: ENT_NETWORK.id, name, city, state, active: true
  });
  if (error) { notif('Erro ao criar filial: ' + error.message, '❌'); return; }
  closeModal('m-branch');
  notif('Filial criada com sucesso!', '🏬');
  await loadEnterprise();
}
