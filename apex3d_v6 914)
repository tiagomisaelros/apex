<style>
:root {
  --bg:#050508; --surface:#0c0c14; --surface2:#12121e;
  --border:rgba(255,255,255,0.07); --border-b:rgba(255,255,255,0.15);
  --accent:#ff6b2b; --accent2:#ff9f6b;
  --blue:#3a86ff; --green:#00ff88; --purple:#8b5cf6;
  --gold:#ffd166; --red:#ff4d6d; --cyan:#00d4ff;
  --text:#f0f0f8; --muted:#7070a0; --dim:#40405a;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'Instrument Sans',sans-serif;min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");opacity:.025;pointer-events:none;z-index:9999}

/* AUTH */
.auth-wrap{display:none;position:fixed;inset:0;background:var(--bg);z-index:1000;align-items:center;justify-content:center}
.auth-wrap.show{display:flex}
.auth-box{background:var(--surface);border:1px solid var(--border-b);border-radius:24px;padding:48px;width:420px}
.auth-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:40px;color:var(--accent);text-align:center;margin-bottom:4px;letter-spacing:-1px}
.auth-sub{text-align:center;font-size:13px;color:var(--muted);margin-bottom:32px}
.auth-tabs{display:flex;gap:4px;background:var(--surface2);border-radius:10px;padding:4px;margin-bottom:24px}
.auth-tab{flex:1;padding:8px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--muted);font-family:'Instrument Sans',sans-serif;transition:all .2s}
.auth-tab.active{background:var(--surface);color:var(--text);border:1px solid var(--border-b)}
.cfg-box{background:rgba(255,107,43,.07);border:1px solid rgba(255,107,43,.25);border-radius:12px;padding:14px 16px;margin-bottom:20px;font-size:12px;line-height:1.6;color:var(--muted)}
.cfg-box strong{color:var(--accent);display:block;margin-bottom:4px}
.cfg-box code{background:rgba(255,255,255,.06);padding:1px 5px;border-radius:4px;font-family:'DM Mono',monospace;color:var(--cyan);font-size:11px}

/* FORMS */
.fg{margin-bottom:14px}
.fl{font-size:11px;color:var(--muted);margin-bottom:6px;display:block;font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.05em}
.fi{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-size:14px;font-family:'Instrument Sans',sans-serif;outline:none;transition:border-color .2s}
.fi:focus{border-color:var(--accent)}
select.fi{cursor:pointer}

/* BUTTONS */
.btn{padding:10px 18px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;border:none;transition:all .2s;font-family:'Instrument Sans',sans-serif;display:inline-flex;align-items:center;justify-content:center;gap:7px}
.btn-p{background:var(--accent);color:#fff;width:100%}
.btn-p:hover{background:#ff7d42;transform:translateY(-1px);box-shadow:0 8px 24px rgba(255,107,43,.35)}
.btn-p:disabled{opacity:.5;cursor:not-allowed;transform:none}
.btn-g{background:transparent;color:var(--muted);border:1px solid var(--border)}
.btn-g:hover{background:var(--surface2);color:var(--text);border-color:var(--border-b)}
.btn-sm{padding:6px 13px;font-size:12px;border-radius:8px}
.msg-err{background:rgba(255,77,109,.1);border:1px solid rgba(255,77,109,.3);border-radius:9px;padding:11px 14px;font-size:13px;color:var(--red);margin-top:14px;display:none}
.msg-err.show{display:block}
.msg-ok{background:rgba(0,255,136,.1);border:1px solid rgba(0,255,136,.3);border-radius:9px;padding:11px 14px;font-size:13px;color:var(--green);margin-top:14px;display:none}
.msg-ok.show{display:block}

/* SIDEBAR */
.sidebar{position:fixed;left:0;top:0;bottom:0;width:72px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:24px 0;z-index:100;gap:8px}
.logo-m{width:40px;height:40px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;color:#fff;margin-bottom:20px;position:relative;cursor:pointer}
.logo-m::after{content:'';position:absolute;inset:-3px;border-radius:13px;background:var(--accent);opacity:.25;filter:blur(8px);z-index:-1}
.ni{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;position:relative;color:var(--dim);border:1px solid transparent}
.ni:hover{background:var(--surface2);color:var(--muted);border-color:var(--border)}
.ni.active{background:rgba(255,107,43,.12);color:var(--accent);border-color:rgba(255,107,43,.3)}
.ni .tip{position:absolute;left:56px;background:var(--surface2);border:1px solid var(--border-b);color:var(--text);padding:5px 11px;border-radius:7px;font-size:11px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .2s;font-family:'DM Mono',monospace}
.ni:hover .tip{opacity:1}
.ndiv{width:32px;height:1px;background:var(--border);margin:6px 0}
.nav-bot{margin-top:auto;display:flex;flex-direction:column;align-items:center;gap:10px}
.ava{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--purple));display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;cursor:pointer;border:2px solid var(--border-b)}

/* MAIN */
.main{margin-left:72px;min-height:100vh;display:flex;flex-direction:column}
.topbar{height:60px;border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 28px;gap:14px;background:rgba(5,5,8,.85);backdrop-filter:blur(20px);position:sticky;top:0;z-index:50}
.pt{font-family:'Syne',sans-serif;font-weight:700;font-size:15px}
.bc{font-family:'DM Mono',monospace;font-size:11px;color:var(--dim);display:flex;align-items:center;gap:5px}
.bc span{color:var(--accent)}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.sp{display:flex;align-items:center;gap:5px;padding:4px 11px;background:rgba(0,255,136,.08);border:1px solid rgba(0,255,136,.2);border-radius:20px;font-family:'DM Mono',monospace;font-size:11px;color:var(--green)}
.sdot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.ub{display:flex;align-items:center;gap:8px;padding:4px 12px 4px 4px;background:var(--surface2);border:1px solid var(--border);border-radius:20px;cursor:pointer}
.ub-name{font-size:12px;color:var(--muted)}
.ub-role{font-size:10px;color:var(--accent);font-family:'DM Mono',monospace}
.content{padding:28px;flex:1}
.view{display:none;animation:fi .3s ease}
.view.active{display:block}
@keyframes fi{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* STATS */
.sg{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
.sc{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:22px;position:relative;overflow:hidden;transition:border-color .2s}
.sc:hover{border-color:var(--border-b)}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--al,var(--accent));opacity:.6}
.sl{font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;font-family:'DM Mono',monospace;margin-bottom:10px}
.sv{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;line-height:1;margin-bottom:6px}
.schange{font-size:12px;color:var(--green);font-family:'DM Mono',monospace}
.schange.down{color:var(--red)}

/* CARDS */
.card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:22px;transition:border-color .2s}
.card:hover{border-color:var(--border-b)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.st{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;display:flex;align-items:center;gap:7px}
.badge{font-family:'DM Mono',monospace;font-size:10px;padding:2px 7px;border-radius:20px;background:rgba(255,107,43,.15);color:var(--accent);border:1px solid rgba(255,107,43,.3)}

/* TAGS */
.tag{display:inline-flex;align-items:center;gap:3px;padding:3px 9px;border-radius:6px;font-size:11px;font-family:'DM Mono',monospace}
.tg{background:rgba(0,255,136,.1);color:var(--green);border:1px solid rgba(0,255,136,.2)}
.tr{background:rgba(255,77,109,.1);color:var(--red);border:1px solid rgba(255,77,109,.2)}
.to{background:rgba(255,107,43,.1);color:var(--accent);border:1px solid rgba(255,107,43,.2)}
.tb{background:rgba(58,134,255,.1);color:var(--blue);border:1px solid rgba(58,134,255,.2)}
.tgold{background:rgba(255,209,102,.1);color:var(--gold);border:1px solid rgba(255,209,102,.2)}
.tpur{background:rgba(139,92,246,.1);color:var(--purple);border:1px solid rgba(139,92,246,.2)}

/* TABLES */
.dt{width:100%;border-collapse:collapse}
.dt th{text-align:left;padding:9px 14px;font-size:11px;color:var(--dim);font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.05em;border-bottom:1px solid var(--border)}
.dt td{padding:11px 14px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.03)}
.dt tr:hover td{background:rgba(255,255,255,.02)}

/* TABS */
.tabs{display:flex;gap:4px;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:4px;width:fit-content;margin-bottom:22px}
.tab{padding:7px 17px;border-radius:9px;font-size:13px;font-weight:500;cursor:pointer;border:none;background:transparent;color:var(--muted);font-family:'Instrument Sans',sans-serif;transition:all .2s}
.tab.active{background:var(--surface2);color:var(--text);border:1px solid var(--border-b)}

/* UPLOAD ZONE */
.upzone{border:2px dashed var(--border-b);border-radius:18px;padding:44px;text-align:center;cursor:pointer;transition:all .3s;background:rgba(255,255,255,.01);position:relative;overflow:hidden}
.upzone::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(255,107,43,.04) 0%,transparent 70%)}
.upzone:hover{border-color:var(--accent);background:rgba(255,107,43,.03)}

/* PHYSICS PRESETS */
.pg{display:grid;grid-template-columns:repeat(5,1fr);gap:9px;margin:16px 0}
.pb{background:var(--surface2);border:1px solid var(--border);border-radius:11px;padding:12px 8px;text-align:center;cursor:pointer;transition:all .2s}
.pb:hover,.pb.active{border-color:var(--accent);background:rgba(255,107,43,.08);color:var(--accent)}
.pi{font-size:20px;margin-bottom:5px}
.pn{font-size:11px;font-weight:500}

/* PROGRESS */
.pb-bar{height:4px;background:var(--surface2);border-radius:2px;overflow:hidden;margin:7px 0}
.pb-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .5s ease}

/* IOT MAP */
.iot-map{background:var(--surface2);border:1px solid var(--border);border-radius:14px;height:240px;position:relative;overflow:hidden}
.map-bg{position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 39px,rgba(255,255,255,.02) 39px,rgba(255,255,255,.02) 40px),repeating-linear-gradient(90deg,transparent,transparent 39px,rgba(255,255,255,.02) 39px,rgba(255,255,255,.02) 40px)}
.mn{position:absolute;width:11px;height:11px;border-radius:50%;background:var(--green);box-shadow:0 0 14px var(--green);animation:pulse 2s infinite;cursor:pointer;transform:translate(-50%,-50%)}
.mn::before{content:'';position:absolute;inset:-5px;border-radius:50%;border:1px solid var(--green);opacity:.3;animation:rip 2s infinite}
@keyframes rip{0%{transform:scale(1);opacity:.3}100%{transform:scale(2.5);opacity:0}}
.mn.off{background:var(--red);box-shadow:0 0 14px var(--red);animation:none}
.mn.off::before{border-color:var(--red);animation:none}
.mn.pend{background:var(--gold);box-shadow:0 0 14px var(--gold);animation:none}

/* PLANS */
.plans-g{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:22px}
.plan-c{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:26px;position:relative;overflow:hidden;cursor:pointer;transition:all .3s}
.plan-c:hover{transform:translateY(-4px);border-color:var(--border-b)}
.plan-c.feat{border-color:rgba(255,107,43,.4);background:linear-gradient(135deg,rgba(255,107,43,.07) 0%,var(--surface) 60%)}
.plan-c.feat::after{content:'MAIS POPULAR';position:absolute;top:14px;right:-28px;background:var(--accent);color:#fff;font-size:9px;font-weight:700;letter-spacing:.1em;padding:4px 40px;transform:rotate(45deg);font-family:'DM Mono',monospace}
.plan-tier{font-family:'DM Mono',monospace;font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px}
.plan-name{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;margin-bottom:4px}
.plan-price{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;color:var(--accent);margin:14px 0 4px}
