// ── ONBOARDING ──
async function checkOnboarding() {
  if (!ME || !PROF) return;
  const role = PROF.role || ME.user_metadata?.role;
  if (role !== 'screen_owner') return;
  if (localStorage.getItem('apex3d_onboarding_done')) return;
  const { count } = await sb.from('devices').select('*', { count: 'exact', head: true }).eq('owner_id', ME.id);
  if ((count || 0) === 0) {
    document.getElementById('m-onboarding').style.display = 'flex';
    obNext(1);
  }
}
function obNext(step) {
  [1,2,3,4].forEach(i => {
    document.getElementById('ob-p'+i).style.display = i===step ? 'block' : 'none';
    const bar = document.getElementById('ob-step-'+i);
    if (bar) bar.style.background = i<=step ? '#ff6b2b' : 'var(--border)';
  });
}
function obGoToScreen() {
  finishOnboarding();
  setTimeout(() => go('iot'), 300);
}
function finishOnboarding() {
  localStorage.setItem('apex3d_onboarding_done', '1');
  document.getElementById('m-onboarding').style.display = 'none';
}
</script>

