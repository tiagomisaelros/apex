function setPipelineStep(step, status, progress) {
  const statusEl = document.getElementById(`step-${step}-status`);
  const barEl    = document.getElementById(`step-${step}-bar`);
  const colors   = { done:'var(--green)', active:'var(--accent)', wait:'var(--muted)', error:'var(--red)' };
  const labels   = { done:'✓ Concluído', active:'⏳ Em andamento...', wait:'Aguardando...', error:'✗ Erro' };
  if (statusEl) { statusEl.textContent = labels[status]||status; statusEl.style.color = colors[status]||colors.wait; }
  if (barEl)    { barEl.style.width = progress+'%'; barEl.style.background = colors[status]||'var(--accent)'; }
}

async function startPipeline() {
  console.log('▶ startPipeline chamado');
  const name = document.getElementById('c-name').value.trim();
  console.log('name:', name, '| SEL_FILE:', !!SEL_FILE, '| base64:', !!CURRENT_FILE_BASE64);
  if (!name)            { notif('Digite o nome da campanha','⚠️'); return; }
  if (!SEL_FILE)        { notif('Faça o upload de uma imagem','⚠️'); return; }
  if (!CURRENT_FILE_BASE64) { notif('Aguarde o carregamento da imagem','⚠️'); return; }

  // Valida saldo fresco do banco (evita cache desatualizado)
  const { data: freshWallet } = await sb.from('wallets').select('credits, balance_brl').eq('user_id', ME.id).maybeSingle();
  if (freshWallet) { WALL = { ...WALL, ...freshWallet }; }
  const credits = WALL?.credits || 0;
