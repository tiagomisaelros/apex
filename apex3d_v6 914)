.plan-feats{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:18px}
.plan-feats li{font-size:13px;color:var(--muted);display:flex;align-items:flex-start;gap:7px}
.plan-feats li::before{content:'✓';color:var(--green);font-size:11px;margin-top:1px;flex-shrink:0}
.plan-feats li.hi{color:var(--text)}

/* WALLET */
.wcard{background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);border:1px solid rgba(58,134,255,.3);border-radius:18px;padding:26px;position:relative;overflow:hidden}
.wcard::before{content:'';position:absolute;top:-40px;right:-40px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(58,134,255,.15) 0%,transparent 70%)}
.wbal{font-family:'Syne',sans-serif;font-size:38px;font-weight:800;color:#fff}
