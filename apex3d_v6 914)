<script>
// ── NOTIFICAÇÕES IN-APP ──────────────────────────────────────────────────
let _notifOpen = false;

function toggleNotifPanel() {
  _notifOpen = !_notifOpen;
  document.getElementById('notif-panel').style.display = _notifOpen ? 'block' : 'none';
  if (_notifOpen) loadNotifications();
}

// Fecha painel ao clicar fora
document.addEventListener('click', function(e) {
  const panel = document.getElementById('notif-panel');
  const bell  = document.getElementById('notif-bell');
  if (_notifOpen && panel && !panel.contains(e.target) && !bell.contains(e.target)) {
    _notifOpen = false;
    panel.style.display = 'none';
  }
});

async function loadNotifications() {
  if (!ME) return;
  const list = document.getElementById('notif-list');
  list.innerHTML = '<div style="padding:20px;text-align:center"><div class="spin" style="margin:0 auto"></div></div>';

  const { data: notifs } = await sb.from('notifications')
    .select('*').eq('user_id', ME.id)
    .order('created_at', { ascending: false }).limit(20);

  if (!notifs || !notifs.length) {
    list.innerHTML = '<div style="padding:40px 20px;text-align:center;color:var(--dim);font-size:13px"><div style="font-size:32px;margin-bottom:8px">🔕</div>Nenhuma notificação</div>';
    return;
  }

  const icons = { video_ready:'🎬', campaign_approved:'✅', campaign_rejected:'❌', booking_confirmed_advertiser:'📅', booking_confirmed_owner:'💰', screen_approved:'📺', welcome:'👋' };

  list.innerHTML = notifs.map(n => {
    const icon = icons[n.type] || '🔔';
    const time = new Date(n.created_at).toLocaleDateString('pt-BR', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
    const unread = !n.read_at;
    return `<div onclick="markRead('${n.id}')" style="padding:14px 20px;border-bottom:1px solid var(--border);cursor:pointer;background:${unread ? 'rgba(255,107,43,0.04)' : 'transparent'};transition:0.2s" onmouseover="this.style.background='var(--surface2)'" onmouseout="this.style.background='${unread ? 'rgba(255,107,43,0.04)' : 'transparent'}'">
      <div style="display:flex;gap:10px;align-items:flex-start">
        <div style="font-size:18px;flex-shrink:0">${icon}</div>
        <div style="flex:1;min-width:0">
          <div style="font-size:13px;font-weight:${unread ? '700' : '400'};color:${unread ? 'var(--text)' : 'var(--muted)'};margin-bottom:3px">${n.title || 'Notificação'}</div>
          <div style="font-size:11px;color:var(--dim);line-height:1.4">${n.body || ''}</div>
          <div style="font-size:10px;color:var(--dim);margin-top:4px">${time}</div>
        </div>
        ${unread ? '<div style="width:7px;height:7px;border-radius:50%;background:#ff6b2b;flex-shrink:0;margin-top:4px"></div>' : ''}
      </div>
    </div>`;
  }).join('');
}

async function markRead(id) {
  await sb.from('notifications').update({ read_at: new Date().toISOString() }).eq('id', id);
  await refreshNotifCount();
  loadNotifications();
}

async function markAllRead() {
  if (!ME) return;
  await sb.from('notifications').update({ read_at: new Date().toISOString() }).eq('user_id', ME.id).is('read_at', null);
  await refreshNotifCount();
  loadNotifications();
}

async function refreshNotifCount() {
  if (!ME) return;
  const { count } = await sb.from('notifications').select('*', { count: 'exact', head: true }).eq('user_id', ME.id).is('read_at', null);
  const badge = document.getElementById('notif-count');
  if (!badge) return;
  if (count > 0) {
    badge.style.display = 'flex';
    badge.textContent = count > 9 ? '9+' : count;
  } else {
    badge.style.display = 'none';
  }
}

// ── PERFIL DO USUÁRIO ────────────────────────────────────────────────────
function openProfileModal() {
  if (!ME || !PROF) return;
  document.getElementById('m-profile').style.display = 'flex';
  // Preenche dados atuais
  const initials = (PROF.full_name || ME.email || '?').split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
  document.getElementById('prof-ava').textContent = initials;
  document.getElementById('prof-email').textContent = ME.email;
  document.getElementById('prof-name').value = PROF.full_name || '';
  const roleLabels = { super_admin:'👑 Super Admin', screen_owner:'📺 Dono de Tela', advertiser:'🧑‍💼 Anunciante', enterprise_admin:'🏢 Enterprise Admin' };
  const badge = document.getElementById('prof-role-badge');
  badge.innerHTML = `<span style="display:inline-block;padding:3px 12px;border-radius:20px;font-size:11px;font-weight:700;background:var(--accent)22;color:var(--accent);border:1px solid var(--accent)44">${roleLabels[PROF.role] || PROF.role}</span>`;
  document.getElementById('prof-pass').value = '';
  document.getElementById('prof-pass2').value = '';
  document.getElementById('prof-err').classList.remove('show');
  document.getElementById('prof-ok').classList.remove('show');
}

async function saveProfile() {
  const name  = document.getElementById('prof-name').value.trim();
  const pass  = document.getElementById('prof-pass').value;
  const pass2 = document.getElementById('prof-pass2').value;
  const btn   = document.getElementById('btn-save-profile');
  const err   = document.getElementById('prof-err');
  const ok    = document.getElementById('prof-ok');

  if (!name) { showErr(err, 'Nome não pode ser vazio'); return; }
  if (pass && pass.length < 8) { showErr(err, 'Senha mínimo 8 caracteres'); return; }
  if (pass && pass !== pass2)  { showErr(err, 'As senhas não coincidem'); return; }

  btn.disabled = true; btn.innerHTML = '<div class="spin"></div> Salvando...';
  err.classList.remove('show');

  try {
    // Atualiza nome no perfil
    const { error: profErr } = await sb.from('profiles').update({ full_name: name }).eq('id', ME.id);
    if (profErr) throw new Error(profErr.message);

    // Atualiza senha se fornecida
    if (pass) {
      const { error: passErr } = await sb.auth.updateUser({ password: pass });
      if (passErr) throw new Error(passErr.message);
    }

    // Atualiza estado local
    if (PROF) PROF.full_name = name;
    document.getElementById('t-name').textContent = name;
    const initials = name.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
    document.getElementById('t-ava').textContent = initials;
    document.getElementById('prof-ava').textContent = initials;

    ok.textContent = '✅ Perfil atualizado com sucesso!';
    ok.classList.add('show');
    if (pass) { ok.textContent = '✅ Perfil e senha atualizados!'; }
  } catch(e) {
    showErr(err, e.message);
  } finally {
    btn.disabled = false; btn.innerHTML = 'Salvar alterações';
  }
}

// ── SESSÃO EXPIRADA (listener integrado ao principal acima) ──────────────

// Verifica sessão a cada 5 minutos
setInterval(async () => {
  if (!ME) return;
  const { data: { session } } = await sb.auth.getSession();
  if (!session) {
    document.getElementById('m-session-expired').style.display = 'flex';
  }
}, 5 * 60 * 1000);
</script>

