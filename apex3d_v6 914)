// ── REPASSES ──────────────────────────────────────────────────────────────
// Cache global para CSV export
let _repassesData = [];

let _repassesToken = 0;
async function loadRepasses() {
  const _t = ++_repassesToken;
  const filter = document.getElementById('rep-filter')?.value || 'all';
  const listEl = document.getElementById('rep-list');
  if (listEl) listEl.innerHTML = '<div style="text-align:center;padding:22px;color:var(--dim);font-size:13px">Carregando...</div>';

  // Busca todos os dados (sem filtro) para gráfico e ranking
  const { data: allData, error: allErr } = await sb.from('revenue_splits')
    .select(`id, total_amount, owner_amount, platform_fee, status, created_at, paid_at,
      bookings ( id, start_time, end_time ),
      devices ( name, location_city, location_state )`)
    .order('created_at', { ascending: false });
  if (_t !== _repassesToken) return;

  if (allErr) {
    if (listEl) listEl.innerHTML = `<div style="text-align:center;padding:22px;color:#ff4d6d;font-size:13px">Erro ao carregar repasses</div>`;
    return;
  }

  const all = allData || [];
  _repassesData = all;

  const fmt = v => 'R$ ' + parseFloat(v).toLocaleString('pt-BR', { minimumFractionDigits: 2 });

  // ── Totais ──
  const pending = all.filter(s => s.status === 'pending');
  const paid    = all.filter(s => s.status === 'paid');
  const totalPending = pending.reduce((a, s) => a + parseFloat(s.owner_amount), 0);
  const totalPaid    = paid.reduce((a, s) => a + parseFloat(s.owner_amount), 0);

  const pendEl = document.getElementById('rep-pending');
  const pendCt = document.getElementById('rep-pending-count');
  const paidEl = document.getElementById('rep-paid');
  const paidCt = document.getElementById('rep-paid-count');
  if (pendEl) pendEl.textContent = fmt(totalPending);
  if (pendCt) pendCt.textContent = `${pending.length} repasse${pending.length !== 1 ? 's' : ''} pendente${pending.length !== 1 ? 's' : ''}`;
  if (paidEl) paidEl.textContent = fmt(totalPaid);
  if (paidCt) paidCt.textContent = `${paid.length} repasse${paid.length !== 1 ? 's' : ''} pago${paid.length !== 1 ? 's' : ''}`;

  // ── Gráfico de receita por mês ──
  const chartEl = document.getElementById('rep-chart');
  if (chartEl) {
    const byMonth = {};
    all.forEach(s => {
      const d = new Date(s.created_at);
      const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
      const label = d.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });
      if (!byMonth[key]) byMonth[key] = { label, value: 0 };
      byMonth[key].value += parseFloat(s.owner_amount);
    });
    const months = Object.values(byMonth).slice(-6);
    if (!months.length) {
      chartEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--dim);font-size:12px;width:100%">Sem dados ainda</div>';
    } else {
      const maxVal = Math.max(...months.map(m => m.value), 1);
      chartEl.innerHTML = months.map(m => {
        const h = Math.max(8, Math.round((m.value / maxVal) * 100));
        const fmtShort = v => 'R$' + (v >= 1000 ? (v/1000).toFixed(1)+'k' : v.toFixed(0));
        return `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px">
          <div style="font-size:10px;color:#00ff88;font-family:'DM Mono',monospace">${fmtShort(m.value)}</div>
          <div style="width:100%;background:linear-gradient(180deg,#00ff88,#00cc66);border-radius:4px 4px 0 0;height:${h}px;min-height:8px;transition:height 0.3s"></div>
          <div style="font-size:10px;color:var(--muted);text-transform:capitalize">${m.label}</div>
        </div>`;
      }).join('');
      chartEl.style.display = 'flex';
    }
  }

  // ── Ranking de telas ──
  const rankEl = document.getElementById('rep-ranking');
  if (rankEl) {
    const byTela = {};
    all.forEach(s => {
      const name = s.devices?.name || 'Desconhecida';
      if (!byTela[name]) byTela[name] = { name, total: 0, count: 0 };
      byTela[name].total += parseFloat(s.owner_amount);
      byTela[name].count++;
    });
    const ranking = Object.values(byTela).sort((a,b) => b.total - a.total).slice(0, 5);
    if (!ranking.length) {
      rankEl.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--dim);font-size:12px">Sem dados ainda</div>';
    } else {
      const maxR = ranking[0].total;
      rankEl.innerHTML = ranking.map((t, i) => {
        const pct = Math.round((t.total / maxR) * 100);
        const medals = ['🥇','🥈','🥉','4°','5°'];
        return `<div style="margin-bottom:12px">
          <div style="display:flex;justify-content:space-between;margin-bottom:5px">
            <span style="font-size:12px;color:var(--text)">${medals[i]} ${t.name}</span>
            <span style="font-size:12px;font-family:'DM Mono',monospace;color:#00ff88">${fmt(t.total)}</span>
          </div>
          <div style="background:var(--surface2);border-radius:4px;height:6px">
            <div style="background:linear-gradient(90deg,#00ff88,#00cc66);border-radius:4px;height:6px;width:${pct}%;transition:width 0.4s"></div>
          </div>
          <div style="font-size:10px;color:var(--dim);margin-top:3px">${t.count} reserva${t.count !== 1 ? 's' : ''}</div>
        </div>`;
      }).join('');
    }
  }

  // ── Histórico filtrado ──
  const splits = filter === 'all' ? all : all.filter(s => s.status === filter);

  if (!splits.length) {
    if (listEl) listEl.innerHTML = '<div style="text-align:center;padding:32px;color:var(--dim);font-size:13px">Nenhum repasse encontrado</div>';
    return;
  }

  const rows = splits.map(s => {
    const statusColor = s.status === 'paid' ? '#00ff88' : s.status === 'cancelled' ? '#ff4d6d' : '#ff6b2b';
    const statusLabel = s.status === 'paid' ? 'Pago' : s.status === 'cancelled' ? 'Cancelado' : 'Pendente';
    const tela = s.devices?.name || '—';
    const cidade = s.devices ? `${s.devices.location_city}/${s.devices.location_state}` : '—';
    const periodo = s.bookings
      ? `${new Date(s.bookings.start_time).toLocaleDateString('pt-BR')} → ${new Date(s.bookings.end_time).toLocaleDateString('pt-BR')}`
      : '—';
    return `
      <div style="padding:14px 0;border-bottom:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr auto auto;align-items:center;gap:12px">
        <div>
          <div style="font-size:13px;font-weight:600;color:var(--text)">${tela}</div>
          <div style="font-size:11px;color:var(--muted);margin-top:2px">${cidade}</div>
          <div style="font-size:11px;color:var(--dim);margin-top:2px">${periodo}</div>
        </div>
        <div>
          <div style="font-size:11px;color:var(--muted);margin-bottom:3px">Total reserva</div>
          <div style="font-size:13px;font-family:'DM Mono',monospace;color:var(--text)">${fmt(s.total_amount)}</div>
          <div style="font-size:11px;color:var(--dim);margin-top:2px">Taxa plataforma: ${fmt(s.platform_fee)}</div>
        </div>
        <div style="text-align:right">
          <div style="font-size:11px;color:var(--muted);margin-bottom:3px">Seu repasse (85%)</div>
          <div style="font-size:18px;font-weight:800;font-family:'DM Mono',monospace;color:#00ff88">${fmt(s.owner_amount)}</div>
        </div>
        <div>
          <span style="padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;background:${statusColor}22;color:${statusColor};border:1px solid ${statusColor}44">${statusLabel}</span>
          ${s.paid_at ? `<div style="font-size:10px;color:var(--dim);margin-top:4px;text-align:center">${new Date(s.paid_at).toLocaleDateString('pt-BR')}</div>` : ''}
        </div>
      </div>`;
  }).join('');

  if (listEl) listEl.innerHTML = rows;
}

function exportRepasses() {
  if (!_repassesData.length) { notif('Nenhum dado para exportar', '⚠️'); return; }
  const fmt2 = v => parseFloat(v||0).toFixed(2).replace('.', ',');
  const isAdmin = PROF?.role === 'super_admin';

  // Headers — admin vê mais colunas
  const header = isAdmin
    ? 'Data,Operador,Tela,Cidade,Status,Total Reserva,Repasse (85%),Taxa Plataforma (15%),Período Início,Período Fim'
    : 'Data,Tela,Cidade,Status,Total Reserva,Repasse (85%),Taxa Plataforma (15%)';

  const rows = _repassesData.map(s => {
    const data    = new Date(s.created_at).toLocaleDateString('pt-BR');
    const tela    = (s.devices?.name || '').replace(/,/g, ';');
    const cidade  = s.devices ? `${s.devices.location_city||''}/${s.devices.location_state||''}` : '';
    const status  = s.status === 'paid' ? 'Pago' : s.status === 'cancelled' ? 'Cancelado' : 'Pendente';
    const inicio  = s.bookings?.start_time ? new Date(s.bookings.start_time).toLocaleDateString('pt-BR') : '';
    const fim     = s.bookings?.end_time   ? new Date(s.bookings.end_time).toLocaleDateString('pt-BR')   : '';
    const operador = (s.profiles?.full_name || s.profiles?.email || '').replace(/,/g,';');
    return isAdmin
      ? `${data},${operador},${tela},${cidade},${status},${fmt2(s.total_amount)},${fmt2(s.owner_amount)},${fmt2(s.platform_fee)},${inicio},${fim}`
      : `${data},${tela},${cidade},${status},${fmt2(s.total_amount)},${fmt2(s.owner_amount)},${fmt2(s.platform_fee)}`;
  });

  // Summary footer for admin
  if (isAdmin) {
    const totalBruto   = _repassesData.reduce((a,s) => a + parseFloat(s.total_amount||0), 0);
    const totalRepasse = _repassesData.reduce((a,s) => a + parseFloat(s.owner_amount||0), 0);
    const totalTaxa    = _repassesData.reduce((a,s) => a + parseFloat(s.platform_fee||0), 0);
    rows.push('');
    rows.push(`TOTAL,,,,,"${fmt2(totalBruto)}","${fmt2(totalRepasse)}","${fmt2(totalTaxa)}",,`);
  }

  const mes = new Date().toLocaleDateString('pt-BR', { month:'long', year:'numeric' });
  const csv = [header, ...rows].join('\n');
  const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `repasses_apex3d_${new Date().toISOString().slice(0,7)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  notif(`CSV exportado — ${_repassesData.length} registros`, '📥');
}

// ── ENTERPRISE ────────────────────────────────────────────────────────────
let ENT_NETWORK = null;

async function loadEnterprise() {
  const _t = _getToken();
  if (!ME) return;
  const role = ME.role || ME.user_metadata?.role;

  // Busca rede do usuário
  let network = null;

  if (role === 'super_admin') {
    // Admin vê a primeira rede cadastrada (ou pode filtrar)
    const { data } = await sb.from('enterprise_networks').select('*').limit(1).maybeSingle();
    network = data;
  } else {
    // Busca via membership
    const { data: member } = await sb.from('enterprise_members')
      .select('network_id, role, enterprise_networks(*)')
      .eq('user_id', ME.id).limit(1).maybeSingle();
    if (member) network = member.enterprise_networks;

    // Ou como owner
    if (!network) {
      const { data } = await sb.from('enterprise_networks')
        .select('*').eq('owner_id', ME.id).limit(1).maybeSingle();
      network = data;
    }
  }
  if (!_tokenValid(_t)) return;

  if (!network) {
    // Mostra planos
    document.getElementById('ent-plans-view').style.display = 'block';
    document.getElementById('ent-dashboard-view').style.display = 'none';
    return;
  }

  ENT_NETWORK = network;
  document.getElementById('ent-plans-view').style.display = 'none';
  document.getElementById('ent-dashboard-view').style.display = 'block';

  // Header
  document.getElementById('ent-name').textContent = network.name;
  const planBadge = document.getElementById('ent-plan-badge');
  planBadge.textContent = network.plan === 'pro' ? '⭐ Pro Network' : '🚀 Starter Network';
  planBadge.style.color = network.plan === 'pro' ? '#ffd166' : '#ff6b2b';
  planBadge.style.borderColor = network.plan === 'pro' ? '#ffd16644' : '#ff6b2b44';
  planBadge.style.background = network.plan === 'pro' ? '#ffd16622' : '#ff6b2b22';

  // White-label: aplica cor primária da rede se definida
  if (network.primary_color) {
    document.documentElement.style.setProperty('--ent-color', network.primary_color);
  }

  // Busca membros da rede para filtrar tabelas que não têm network_id
  const { data: netMembers } = await sb.from('enterprise_members')
    .select('user_id').eq('network_id', network.id).eq('status', 'active');
  // Inclui também o owner da rede
  const ownerIdSet = new Set((netMembers || []).map(m => m.user_id));
  if (network.owner_id) ownerIdSet.add(network.owner_id);
  const memberIds = [...ownerIdSet];

  // Stats em paralelo
  const [branchRes, screenRes, campRes, approvalRes] = await Promise.all([
    sb.from('enterprise_branches').select('*', { count: 'exact' }).eq('network_id', network.id).eq('active', true),
    memberIds.length
      ? sb.from('devices').select('*', { count: 'exact' }).in('owner_id', memberIds)
      : Promise.resolve({ data: [], count: 0 }),
    memberIds.length
      ? sb.from('campaigns').select('*', { count: 'exact' }).in('user_id', memberIds)
      : Promise.resolve({ data: [], count: 0 }),
    sb.from('enterprise_approvals').select('*, campaigns(name), profiles!requested_by(name)', { count: 'exact' }).eq('network_id', network.id).eq('status', 'pending'),
  ]);
  if (!_tokenValid(_t)) return;

  const branches  = branchRes.data || [];
  const screens   = screenRes.data || [];
  const pendCount = approvalRes.count || 0;

  document.getElementById('ent-branches').textContent = branchRes.count ?? 0;
  document.getElementById('ent-screens').textContent  = screenRes.count ?? 0;
  document.getElementById('ent-camps').textContent    = campRes.count ?? 0;
  document.getElementById('ent-pending').textContent  = pendCount;

  // Botão de aprovações
  const appBtn = document.getElementById('ent-approve-btn');
  if (appBtn) {
    appBtn.style.display = pendCount > 0 ? 'flex' : 'none';
    const sp = document.getElementById('ent-pending-count');
    if (sp) sp.textContent = pendCount;
  }

  // Lista de filiais
  const brListEl = document.getElementById('ent-branches-list');
  if (brListEl) {
    if (!branches.length) {
      brListEl.innerHTML = '<div style="text-align:center;padding:22px;color:var(--dim);font-size:13px">Nenhuma filial cadastrada</div>';
