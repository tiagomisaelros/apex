<script>
// ── CANCELAR RESERVA ─────────────────────────────────────────────────────
let _cancelBookingId = null;
let _cancelBookingCredits = 0;

function confirmCancelBooking(bookingId, screenName, credits) {
  _cancelBookingId = bookingId;
  _cancelBookingCredits = credits;
  document.getElementById('cancel-booking-desc').textContent = `Cancelar reserva na tela "${screenName}"`;
  document.getElementById('cancel-credits-val').textContent = credits + ' créditos';
  openModal('m-cancel-booking');
}

async function doCancelBooking() {
  if (!_cancelBookingId) return;
  const btn = document.getElementById('btn-confirm-cancel');
  btn.disabled = true; btn.innerHTML = '<div class="spin"></div> Cancelando...';

  try {
    // Cancela a reserva
    const { error: cancelErr } = await sb.from('bookings')
      .update({ status: 'cancelled', cancelled_at: new Date().toISOString() })
      .eq('id', _cancelBookingId);
    if (cancelErr) throw new Error(cancelErr.message);

    // Reembolsa créditos
    if (_cancelBookingCredits > 0) {
      const { error: walletErr } = await sb.rpc('add_credits', {
        p_user_id: ME.id,
        p_credits: _cancelBookingCredits,
        p_description: 'Reembolso de cancelamento de reserva'
      });
      if (walletErr) {
        // Fallback: update direto se RPC não existir
        const { data: wallet } = await sb.from('wallets').select('credits').eq('user_id', ME.id).maybeSingle();
        if (wallet) {
          await sb.from('wallets').update({ credits: wallet.credits + _cancelBookingCredits }).eq('user_id', ME.id);
        }
      }
    }

    closeModal('m-cancel-booking');
    notif(`Reserva cancelada. ${_cancelBookingCredits} créditos reembolsados! ✅`, '💳');

    // Refresh wallet e campanhas
    const { data: freshWallet } = await sb.from('wallets').select('*').eq('user_id', ME.id).maybeSingle();
    if (freshWallet) {
      WALL = freshWallet;
      document.getElementById('saldo-atual').textContent = `${WALL.credits} créditos disponíveis`;
    }
    _loadingCampaigns = false;
    loadCampaigns();

  } catch(e) {
    notif('Erro ao cancelar: ' + e.message, '❌');
  } finally {
    btn.disabled = false; btn.innerHTML = 'Confirmar cancelamento';
    _cancelBookingId = null;
  }
}

// ── BLOQUEAR HORÁRIOS ────────────────────────────────────────────────────
let _blockDeviceId = null;

function openBlockModal(deviceId, deviceName, currentStatus) {
  _blockDeviceId = deviceId;
  const isBlocked = currentStatus === 'maintenance';

  document.getElementById('block-modal-title').textContent = isBlocked
    ? '🔓 Desbloquear Tela'
    : '🔒 Bloquear Tela';

  if (isBlocked) {
    document.getElementById('block-modal-body').innerHTML = `
      <div style="text-align:center;padding:12px 0 20px">
        <div style="font-size:40px;margin-bottom:12px">🔓</div>
        <div style="font-size:14px;color:var(--text);margin-bottom:8px">${deviceName}</div>
        <div style="font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:20px">
          Ao desbloquear, a tela voltará a ficar disponível para novas reservas no marketplace.
        </div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-g" style="flex:1" onclick="closeModal('m-block-screen')">Cancelar</button>
        <button class="btn btn-p" style="flex:1" onclick="doBlockScreen(false)">🔓 Desbloquear</button>
      </div>`;
  } else {
    document.getElementById('block-modal-body').innerHTML = `
      <div style="font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:16px">
        Bloqueie <strong style="color:var(--text)">${deviceName}</strong> por um período de manutenção ou indisponibilidade. Novas reservas não serão aceitas durante o bloqueio.
      </div>
      <div class="fg">
        <label class="fl">Motivo do bloqueio</label>
        <select class="fi" id="block-reason">
          <option value="maintenance">⚙️ Manutenção técnica</option>
          <option value="holiday">📅 Feriado / Fechado</option>
          <option value="setup">🔧 Instalação / Ajuste</option>
          <option value="other">📝 Outro motivo</option>
        </select>
      </div>
      <div class="fg">
        <label class="fl">Observação (opcional)</label>
        <input class="fi" id="block-note" type="text" placeholder="Ex: Manutenção elétrica programada">
      </div>
      <div style="background:rgba(255,193,7,.08);border:1px solid rgba(255,193,7,.2);border-radius:10px;padding:12px;font-size:12px;color:var(--muted);margin-bottom:20px">
        ⚠️ Reservas já confirmadas <strong>não são canceladas</strong> automaticamente. Você precisará negociar com os anunciantes.
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-g" style="flex:1" onclick="closeModal('m-block-screen')">Cancelar</button>
        <button class="btn" style="flex:1;background:#ffc107;color:#000;font-weight:700" onclick="doBlockScreen(true)">🔒 Bloquear tela</button>
      </div>`;
  }

  openModal('m-block-screen');
}

async function doBlockScreen(block) {
  if (!_blockDeviceId) return;
  const reason = document.getElementById('block-reason')?.value || 'maintenance';
  const note   = document.getElementById('block-note')?.value   || '';
  const newStatus = block ? 'maintenance' : 'active';

  const { error } = await sb.from('devices')
    .update({ status: newStatus, maintenance_note: note || null })
    .eq('id', _blockDeviceId);

  if (error) { notif('Erro: ' + error.message, '❌'); return; }

  closeModal('m-block-screen');
  notif(block ? '🔒 Tela bloqueada para manutenção' : '🔓 Tela desbloqueada com sucesso', block ? '⚙️' : '✅');
  await loadDevices();
}
</script>

