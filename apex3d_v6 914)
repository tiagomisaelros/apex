      setTimeout(() => {
        const galBtn = document.querySelector('#tabs-creative .tab:nth-child(2)');
        if (galBtn) { crtab(galBtn, 'cr-gallery'); loadCampaigns(); }
      }, 3000);
    } else {
      notif('Erro no pipeline: ' + e.message,'❌');
      document.getElementById('pipeline-eta').textContent = '❌ ' + e.message;
    }
  }

  btn.disabled = false;
  btn.innerHTML = '⚡ Gerar Vídeo 3D com IA';
}


async function pollStep(step, token, campaignId, type, maxSeconds = 600) {
  const startTime = Date.now();
  const POLL_INTERVAL = 8000; // 8s entre cada check
  const label = step === 'kling' ? 'WAN 2.6' : 'FLUX.2';

  // Solicita Wake Lock para evitar throttling quando aba perde foco
  let wakeLock = null;
  try {
    if ('wakeLock' in navigator) {
      wakeLock = await navigator.wakeLock.request('screen');
    }
  } catch(e) { /* Wake Lock não suportado — continua sem ele */ }

  // Avisa usuário para não trocar de aba
  notif('⚠️ Mantenha esta aba ativa durante a geração para melhor performance', '🎬');

  // Listener para reativar wake lock se perder foco
  const reacquireWakeLock = async () => {
    if (wakeLock !== null && document.visibilityState === 'visible') {
      try { wakeLock = await navigator.wakeLock.request('screen'); } catch(e) {}
    }
  };
  document.addEventListener('visibilitychange', reacquireWakeLock);

  try {
  while (true) {
    await new Promise(r => setTimeout(r, POLL_INTERVAL));

    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    const mins = Math.floor(elapsed / 60);
    const secs = elapsed % 60;
    const elapsedStr = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;
    const progress = Math.min(92, (elapsed / maxSeconds) * 100);

    setPipelineStep(step, 'active', progress);
    document.getElementById('pipeline-eta').textContent =
      `⏱️ ${label} gerando... ${elapsedStr} decorridos`;

    // 1. Verifica direto no banco (mais confiável)
    const { data: camp } = await sb.from('campaigns')
      .select('video_url, processed_image_url, status, ai_job_id')
      .eq('id', campaignId).single();

    if (type === 'video' && camp?.video_url) {
      document.getElementById('pipeline-eta').textContent = `✅ Vídeo pronto em ${elapsedStr}!`;
      sb.from('campaigns').update({ status: 'approved' }).eq('id', campaignId).then(() => {});
      return camp.video_url;
    }
    if (type === 'image' && camp?.processed_image_url) return camp.processed_image_url;
    if (camp?.status === 'rejected') throw new Error('Conteúdo reprovado na moderação.');

    // 2. Se tiver job_id, verifica via Edge Function
    if (camp?.ai_job_id) {
      try {
        const checkRes = await fetch(`${SUPABASE_FUNCTIONS_URL}/ai-check-video`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${token}`,
            'Content-Type': 'application/json',
            'apikey': SUPABASE_KEY,
          },
          body: JSON.stringify({ campaign_id: campaignId }),
        });

        if (checkRes.ok) {
          const checkData = await checkRes.json();

          if (checkData.status === 'completed') {
            // Busca URL final no banco após salvar
            await new Promise(r => setTimeout(r, 2000));
            const { data: updated } = await sb.from('campaigns')
              .select('video_url').eq('id', campaignId).single();
            const url = updated?.video_url || checkData.video_url;
            if (url) {
              document.getElementById('pipeline-eta').textContent = `✅ Vídeo pronto em ${elapsedStr}!`;
              sb.from('campaigns').update({ status: 'approved' }).eq('id', campaignId).then(() => {});
              return url;
            }
          }
          if (checkData.status === 'failed') throw new Error(`${label} falhou: ${checkData.message || 'Erro desconhecido'}`);
        }
      } catch(e) {
        if (e.message.includes('falhou')) throw e;
        console.warn('Check error (continuando polling):', e.message);
      }
    }

    // 3. Timeout máximo
    if (elapsed > maxSeconds) {
      const { data: final } = await sb.from('campaigns')
        .select('video_url, status').eq('id', campaignId).single();
      if (final?.video_url) {
        document.removeEventListener('visibilitychange', reacquireWakeLock);
        if (wakeLock) wakeLock.release();
        return final.video_url;
      }
      document.removeEventListener('visibilitychange', reacquireWakeLock);
      if (wakeLock) wakeLock.release();
      throw new Error(`Timeout após ${elapsedStr}. O vídeo pode estar disponível em "Minhas Campanhas" em breve.`);
    }
  }
  } finally {
    // Sempre libera wake lock e remove listener ao sair do polling
    document.removeEventListener('visibilitychange', reacquireWakeLock);
    try { if (wakeLock) wakeLock.release(); } catch(e) {}
  }
}

async function submitForApproval() {
  if (!CURRENT_CAMPAIGN_ID) return;

  const btn = event?.target;
  if (btn) { btn.disabled = true; btn.textContent = '🤖 IA moderando...'; }

  try {
    const token = (await sb.auth.getSession()).data.session?.access_token;

    // Chama moderação automática por IA
    const res = await fetch(`${SUPABASE_FUNCTIONS_URL}/ai-auto-approve`, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json',
        'apikey': SUPABASE_KEY,
      },
      body: JSON.stringify({ campaign_id: CURRENT_CAMPAIGN_ID }),
    });

    const data = await res.json();

    // Esconde player e pipeline
    document.getElementById('video-result').style.display = 'none';
    document.getElementById('pipeline-status').style.display = 'none';
    CURRENT_CAMPAIGN_ID = null;

    if (data.auto_approved) {
      notif(`✅ Aprovado pela IA! Score: ${data.score}/100. Pronto para agendamento!`, '🤖');
    } else if (data.needs_human_review) {
      notif(`⏳ Score: ${data.score}/100. Enviado para revisão humana.`, '📋');
    } else if (data.rejected) {
      notif(`❌ Reprovado pela IA (score: ${data.score}/100). ${data.message}`, '⚠️');
    } else {
      notif('Campanha processada!', '📋');
    }

    // Vai para Minhas Campanhas
    setTimeout(() => {
      const galBtn = document.querySelector('#tabs-creative .tab:nth-child(2)');
      if (galBtn) { crtab(galBtn, 'cr-gallery'); loadCampaigns(); }
    }, 1500);

  } catch(e) {
    console.error('submitForApproval error:', e);
    // Fallback: envia para fila humana
    await sb.from('campaigns').update({ status: 'review' }).eq('id', CURRENT_CAMPAIGN_ID);
    notif('Enviado para revisão manual.', '📋');
    const tabs = document.querySelectorAll('#tabs-creative .tab');
    if (tabs[1]) tabs[1].click();
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = 'Enviar para aprovação →'; }
  }
}

async function downloadVideoUrl(url, name) {
  try {
    notif('Preparando download...', '⬇️');
    const res = await fetch(url);
    if (!res.ok) throw new Error('fetch failed');
    const blob = await res.blob();
    const blobUrl = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = blobUrl;
    a.download = `apex3d_${name || 'video'}.mp4`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(blobUrl), 5000);
    notif('Download iniciado!', '✅');
  } catch(e) {
    notif('Abrindo em nova aba — salve com botão direito', '⬇️');
    window.open(url, '_blank');
  }
}

async function downloadVideo() {
