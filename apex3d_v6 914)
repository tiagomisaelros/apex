.screens-g{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.scard{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;cursor:pointer;transition:all .3s}
.scard:hover{transform:translateY(-4px);border-color:var(--border-b);box-shadow:0 14px 40px rgba(0,0,0,.4)}
.sthumb{height:110px;display:flex;align-items:center;justify-content:center;font-size:32px;position:relative}
.sinfo{padding:14px}
.sname{font-size:14px;font-weight:600;margin-bottom:3px}
.sloc{font-size:11px;color:var(--muted);margin-bottom:8px;font-family:'DM Mono',monospace}
.sprice{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;color:var(--accent)}
.sprice span{font-size:11px;color:var(--muted)}

/* TX LIST */
.tx-list{display:flex;flex-direction:column;gap:8px}
