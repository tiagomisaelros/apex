.tx-d{color:var(--red)}

/* MODAL */
.mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);z-index:500;align-items:center;justify-content:center}
.mo.show{display:flex}
.mbox{background:var(--surface);border:1px solid var(--border-b);border-radius:22px;padding:34px;width:480px;max-height:80vh;overflow-y:auto;animation:fi .3s ease}
.mt{font-family:'Syne',sans-serif;font-size:21px;font-weight:800;margin-bottom:5px}
.ms{font-size:13px;color:var(--muted);margin-bottom:22px}

/* NOTIF */
.notif{position:fixed;top:76px;right:22px;background:var(--surface2);border:1px solid var(--border-b);border-radius:13px;padding:14px 18px;display:flex;align-items:center;gap:11px;font-size:13px;z-index:9000;transform:translateX(120%);transition:transform .4s cubic-bezier(.34,1.56,.64,1);max-width:300px;box-shadow:0 14px 44px rgba(0,0,0,.5)}
.notif.show{transform:translateX(0)}

/* LOADING */
.spin{width:18px;height:18px;border:2px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:sp .8s linear infinite;display:inline-block}
@keyframes sp{to{transform:rotate(360deg)}}

/* EMPTY */
.empty{text-align:center;padding:44px 20px}
.empty-i{font-size:44px;margin-bottom:14px;opacity:.45}
.empty-t{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;margin-bottom:6px;color:var(--muted)}
.empty-s{font-size:13px;color:var(--dim)}

/* FEAT GRID */
.fg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:18px}
.fi-card{background:var(--surface2);border:1px solid var(--border);border-radius:13px;padding:18px;transition:all .2s}
.fi-card:hover{border-color:var(--border-b);transform:translateY(-2px)}
.fi-icon{width:38px;height:38px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:19px;margin-bottom:11px}
.fi-name{font-size:14px;font-weight:600;margin-bottom:5px}
.fi-desc{font-size:12px;color:var(--muted);line-height:1.5}

/* ENTERPRISE BADGE */
.ent-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;background:linear-gradient(135deg,rgba(255,209,102,.15),rgba(255,107,43,.15));border:1px solid rgba(255,209,102,.3);border-radius:20px;font-size:11px;font-family:'DM Mono',monospace;color:var(--gold)}

/* RANGE SLIDER */
input[type=range]{-webkit-appearance:none;width:100%;height:4px;background:var(--surface2);border-radius:2px;outline:none}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:15px;height:15px;border-radius:50%;background:var(--accent);cursor:pointer;border:2px solid var(--bg)}

::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border-b);border-radius:3px}

@keyframes shake {
  0%,100% { transform: translateX(0); }
  20%      { transform: translateX(-6px); }
  40%      { transform: translateX(6px); }
  60%      { transform: translateX(-4px); }
  80%      { transform: translateX(4px); }
}
</style>
