async function loadMe(user) {
  ME = user;

  // Tenta carregar perfil com retry (trigger pode demorar)
  let attempts = 0;
  while (attempts < 3) {
    const { data:p } = await sb.from('profiles').select('*').eq('id',user.id).single();
    if (p) { PROF = p; break; }
    await new Promise(r => setTimeout(r, 800));
    attempts++;
  }

  // Cria perfil manualmente se trigger falhou
  if (!PROF) {
    const { data:p2 } = await sb.from('profiles').upsert({
      id: user.id,
      full_name: user.user_metadata?.full_name || user.email,
      role: user.user_metadata?.role || 'advertiser'
    }, { onConflict: 'id' }).select().maybeSingle();
    PROF = p2;
  }

  // Carrega ou cria carteira
  const { data:w, error:wErr } = await sb.from('wallets').select('*').eq('user_id',user.id).maybeSingle();
  if (w) {
    WALL = w;
  } else {
    const { data:w2 } = await sb.from('wallets').upsert({
      user_id: user.id, credits: 2, balance_brl: 0
    }, { onConflict: 'user_id' }).select().maybeSingle();
    WALL = w2;
  }

  applyUI();
}

