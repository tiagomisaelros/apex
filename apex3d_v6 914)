async function handleFillerFile(input) {
  const file = input.files[0];
  if (!file) return;

  const maxMB = 200;
  if (file.size > maxMB * 1024 * 1024) {
    notif(`Arquivo muito grande. Máximo ${maxMB}MB`, '⚠️');
    input.value = '';
    return;
  }

  // Auto-fill name if empty
  if (!document.getElementById('fl-name').value) {
    document.getElementById('fl-name').value = file.name.replace(/\.[^.]+$/, '');
  }

  document.getElementById('fl-upload-text').textContent = `✅ ${file.name} (${(file.size/1024/1024).toFixed(1)}MB) — pronto para enviar`;
  document.getElementById('fl-upload-area').style.borderColor = 'var(--green)';
}

function handleFillerDrop(event) {
  event.preventDefault();
  document.getElementById('fl-upload-area').style.borderColor = 'var(--border)';
  const file = event.dataTransfer.files[0];
  if (file) {
    document.getElementById('fl-file').files = event.dataTransfer.files;
    handleFillerFile(document.getElementById('fl-file'));
  }
}

async function saveFiller() {
  const name     = document.getElementById('fl-name').value.trim();
  const manualUrl= document.getElementById('fl-url').value.trim();
  const duration = parseInt(document.getElementById('fl-duration').value) || 15;
  const scope    = document.getElementById('fl-scope').value;
  const screenId = scope === 'screen' ? document.getElementById('fl-screen').value : null;
  const fileInput= document.getElementById('fl-file');
  const file     = fileInput.files[0];

  if (!name) { notif('Digite o nome do vídeo','⚠️'); return; }
  if (!file && !manualUrl) { notif('Selecione um vídeo ou cole uma URL','⚠️'); return; }

  let videoUrl = manualUrl;

  // Upload para Supabase Storage se tiver arquivo
  if (file) {
    const ext      = file.name.split('.').pop();
    const fileName = `${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;

    // Mostrar progresso
    document.getElementById('fl-upload-progress').style.display = 'block';
    document.getElementById('fl-progress-bar').style.width = '30%';
    document.getElementById('fl-progress-text').textContent = 'Enviando vídeo...';

    const { data: uploadData, error: uploadErr } = await sb.storage
      .from('filler-videos')
      .upload(fileName, file, { contentType: file.type, upsert: false });

    if (uploadErr) {
      notif('Erro no upload: ' + uploadErr.message, '❌');
      document.getElementById('fl-upload-progress').style.display = 'none';
      return;
    }

    document.getElementById('fl-progress-bar').style.width = '80%';
    document.getElementById('fl-progress-text').textContent = 'Finalizando...';

    // Pegar URL pública
    const { data: urlData } = sb.storage.from('filler-videos').getPublicUrl(fileName);
    videoUrl = urlData.publicUrl;

    document.getElementById('fl-progress-bar').style.width = '100%';
    document.getElementById('fl-progress-text').textContent = 'Upload concluído!';
  }

  const { error } = await sb.from('filler_content').insert({
    name, video_url: videoUrl, duration_seconds: duration,
    scope, screen_id: screenId, owner_id: ME.id,
    is_active: true, sort_order: 0,
  });

  if (error) { notif('Erro: ' + error.message, '❌'); return; }
  notif('Conteúdo adicionado!', '🎬');
  closeFillerModal();
  loadFiller();
}

async function deleteFiller(id) {
  if (!confirm('Remover este conteúdo de preenchimento?')) return;
  const { error } = await sb.from('filler_content').update({ is_active: false }).eq('id', id);
  if (error) { notif('Erro ao remover', '❌'); return; }
  notif('Removido!', '🗑️');
  loadFiller();
}


