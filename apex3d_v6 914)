async function saveBooking() {
  if (!BOOK_DEV) return;
  const campaignId = document.getElementById('book-campaign').value;
  const start      = document.getElementById('book-start').value;
  const end        = document.getElementById('book-end').value;

  if (!campaignId) { notif('Selecione uma campanha aprovada','⚠️'); return; }
  if (!start||!end) { notif('Selecione as datas','⚠️'); return; }
  if (new Date(end) <= new Date(start)) { notif('Data de término deve ser após o início','⚠️'); return; }

  const btn = event?.target;
  if (btn) { btn.disabled=true; btn.innerHTML='<div class="spin"></div> Confirmando...'; }

  try {
    const hours      = (new Date(end) - new Date(start)) / 3600000;
    const totalSlots = Math.floor(hours * (BOOK_DEV.slots_per_hour || 12));
    const totalPrice = totalSlots * (BOOK_DEV.price_per_slot || 0) * 1.15; // +15% taxa

    // 1. Inserir booking
    const { data: booking, error: bkErr } = await sb.from('bookings').insert({
      campaign_id:      campaignId,
      screen_id:        BOOK_DEV.id,
      device_id:        BOOK_DEV.device_id || null,
      screen_owner_id:  BOOK_DEV.owner_id || null,
      advertiser_id:    ME.id,
      starts_at:        new Date(start).toISOString(),
      ends_at:          new Date(end).toISOString(),
      total_slots:      totalSlots,
      total_price:      totalPrice,
      status:           'pending',
    }).select().single();

    if (bkErr) throw new Error('Erro ao criar reserva: ' + bkErr.message);

    // 2. Confirmar e gerar fila via RPC
    const { data: rpcResult, error: rpcErr } = await sb.rpc('confirm_booking_with_queue', { p_booking_id: booking.id });

    if (rpcErr) throw new Error('Erro ao confirmar reserva: ' + rpcErr.message);
    if (rpcResult?.success === false) throw new Error('Erro ao confirmar reserva: ' + (rpcResult?.error || 'Erro desconhecido'));

    closeModal('m-book');

    const slots = rpcResult?.slots_created || totalSlots;
    notif(`✅ Reserva confirmada! ${slots} slots agendados na fila de reprodução.`, '🎉');

    // 3. Buscar dados para notificações
    const { data: camp } = await sb.from('campaigns').select('name').eq('id', campaignId).single();
    const startFmt = new Date(start).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' });
    const endFmt   = new Date(end).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' });
    const totalBrl = totalPrice.toFixed(2);
    const ownerAmount = (totalPrice * 0.85).toFixed(2);
    const feeAmount   = (totalPrice * 0.15).toFixed(2);

    // Notifica anunciante
    sendNotification('booking_confirmed_advertiser', ME.id, {
      screen_name: BOOK_DEV.name,
      campaign_name: camp?.name || '—',
      start: startFmt,
      end: endFmt,
      total: totalBrl,
    });

    // Notifica dono da tela
    if (BOOK_DEV.owner_id) {
      sendNotification('booking_confirmed_owner', BOOK_DEV.owner_id, {
        screen_name: BOOK_DEV.name,
        start: startFmt,
        end: endFmt,
        owner_amount: ownerAmount,
        fee_amount: feeAmount,
      });
    }

    BOOK_DEV = null;

  } catch(e) {
    console.error('saveBooking error:', e);
    notif('Erro ao confirmar reserva: ' + e.message, '❌');
  } finally {
    if (btn) { btn.disabled=false; btn.innerHTML='Confirmar Reserva →'; }
  }
}

// ── ANALYTICS ──
let _analyticsToken = 0;
async function loadAnalytics() {
  const _t = ++_analyticsToken;
  if (!ME) return;
  const role = PROF?.role;
  const campFilter = document.getElementById('an-camp-filter')?.value || 'all';

  // Busca campanhas
  let campQ = sb.from('campaigns').select('id, name, status, created_at, total_views, avg_attention_sec, avg_mood_score');
  if (role !== 'super_admin') campQ = campQ.eq('user_id', ME.id);
  const { data: camps } = await campQ;
  if (_t !== _analyticsToken) return;

  // Popula filtro de campanha
  const filterEl = document.getElementById('an-camp-filter');
  if (filterEl && camps?.length) {
    const current = filterEl.value;
    filterEl.innerHTML = '<option value="all">Todas as campanhas</option>' +
      (camps||[]).map(c => `<option value="${c.id}" ${current===c.id?'selected':''}>${c.name}</option>`).join('');
  }

  // Busca audience_analytics
  let audQ = sb.from('audience_analytics').select('*');
  if (campFilter !== 'all') audQ = audQ.eq('campaign_id', campFilter);
  else if (role !== 'super_admin' && camps?.length) {
    audQ = audQ.in('campaign_id', camps.map(c => c.id));
  }
  const { data: analytics } = await audQ.order('captured_at', { ascending: false }).limit(500);
  const aud = analytics || [];

  // ── Stats globais ──
  const totalPeople = aud.reduce((a, r) => a + (r.people_count || 0), 0);
  const avgAttn = aud.length ? (aud.reduce((a, r) => a + parseFloat(r.attention_avg_seconds || 0), 0) / aud.length).toFixed(1) : 0;
  const positiveMoods = aud.filter(r => r.mood === 'positive').length;
  const moodPct = aud.length ? Math.round((positiveMoods / aud.length) * 100) : 0;

  // CPM médio
  let totalSpend = 0, totalPersons = 0;
  if (camps?.length) {
    const campIds = campFilter !== 'all' ? [campFilter] : camps.map(c => c.id);
    const { data: bookData } = await sb.from('bookings')
      .select('total_price, campaign_id')
      .in('campaign_id', campIds)
      .eq('status', 'confirmed');
    totalSpend = (bookData || []).reduce((a, b) => a + parseFloat(b.total_price || 0), 0);
    totalPersons = totalPeople;
  }
  const cpm = totalPersons > 0 ? ((totalSpend / totalPersons) * 1000).toFixed(2) : 0;

  document.getElementById('an-v').textContent   = totalPeople.toLocaleString('pt-BR');
  document.getElementById('an-a').textContent   = `${avgAttn}s`;
  document.getElementById('an-cpm').textContent = `R$${parseFloat(cpm).toFixed(2)}`;
  document.getElementById('an-m').textContent   = `${moodPct}%`;

  // ── Heatmap de horários ──
  const heatEl = document.getElementById('an-heatmap');
  if (heatEl) {
    const byHour = Array(24).fill(0);
    aud.forEach(r => { if (r.hour_of_day !== null) byHour[r.hour_of_day] += r.people_count || 0; });
    const maxH = Math.max(...byHour, 1);
    heatEl.innerHTML = byHour.map((v, h) => {
      const intensity = Math.round((v / maxH) * 100);
      const color = intensity > 66 ? '#ff6b2b' : intensity > 33 ? '#ffd166' : '#00ff88';
      const opacity = Math.max(0.1, intensity / 100);
      return `<div title="${h}h: ${v} pessoas" style="
        height:40px;border-radius:4px;cursor:default;
        background:${color};opacity:${opacity};
        transition:opacity 0.3s;position:relative
      ">
        <div style="position:absolute;bottom:-16px;left:50%;transform:translateX(-50%);font-size:9px;color:var(--dim);white-space:nowrap">${h%6===0?h+'h':''}</div>
      </div>`;
    }).join('');
  }

  // ── Perfil demográfico ──
  const demoEl = document.getElementById('an-demo');
  if (demoEl && aud.length) {
    const avgMale   = (aud.reduce((a,r)=>a+parseFloat(r.pct_male||0),0)/aud.length).toFixed(0);
    const avgFemale = (aud.reduce((a,r)=>a+parseFloat(r.pct_female||0),0)/aud.length).toFixed(0);
    const avg1824   = (aud.reduce((a,r)=>a+parseFloat(r.pct_age_18_24||0),0)/aud.length).toFixed(0);
    const avg2534   = (aud.reduce((a,r)=>a+parseFloat(r.pct_age_25_34||0),0)/aud.length).toFixed(0);
    const avg3544   = (aud.reduce((a,r)=>a+parseFloat(r.pct_age_35_44||0),0)/aud.length).toFixed(0);
    const avg45p    = (aud.reduce((a,r)=>a+parseFloat(r.pct_age_45_plus||0),0)/aud.length).toFixed(0);

    const bar = (label, pct, color) => `
      <div style="margin-bottom:10px">
        <div style="display:flex;justify-content:space-between;margin-bottom:4px">
          <span style="font-size:12px;color:var(--text)">${label}</span>
          <span style="font-size:12px;font-family:'DM Mono',monospace;color:${color}">${pct}%</span>
        </div>
        <div style="background:var(--surface2);border-radius:4px;height:6px">
          <div style="background:${color};border-radius:4px;height:6px;width:${pct}%;transition:width 0.4s"></div>
        </div>
      </div>`;

    demoEl.innerHTML = `
      <div style="margin-bottom:14px">
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em">Gênero</div>
        ${bar('👨 Masculino', avgMale, '#3a86ff')}
        ${bar('👩 Feminino', avgFemale, '#ff6b2b')}
      </div>
      <div>
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em">Faixa Etária</div>
        ${bar('18–24 anos', avg1824, '#00ff88')}
        ${bar('25–34 anos', avg2534, '#ffd166')}
        ${bar('35–44 anos', avg3544, '#ff6b2b')}
        ${bar('45+ anos',   avg45p,  '#8b5cf6')}
      </div>`;
  } else if (demoEl) {
    demoEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--dim);font-size:12px">Sem dados demográficos ainda</div>';
  }

  // ── Tabela por campanha ──
  const tableEl = document.getElementById('an-table');
  if (!camps || !camps.length) {
    tableEl.innerHTML = '<div class="empty"><div class="empty-i">📊</div><div class="empty-t">Sem campanhas</div></div>';
    return;
  }

  // Agrupa analytics por campanha
  const audByCamp = {};
  aud.forEach(r => {
    if (!r.campaign_id) return;
    if (!audByCamp[r.campaign_id]) audByCamp[r.campaign_id] = [];
    audByCamp[r.campaign_id].push(r);
  });

  const rows = camps.map(c => {
    const rows = audByCamp[c.id] || [];
    const people = rows.reduce((a, r) => a + (r.people_count || 0), 0);
    const attn = rows.length ? (rows.reduce((a,r)=>a+parseFloat(r.attention_avg_seconds||0),0)/rows.length).toFixed(1) : '—';
    const pos = rows.filter(r=>r.mood==='positive').length;
    const mPct = rows.length ? Math.round((pos/rows.length)*100) : 0;
    const moodIcon = mPct > 60 ? '😊' : mPct > 30 ? '😐' : rows.length ? '😞' : '—';
    return `<tr>
      <td style="font-weight:600">${c.name}</td>
      <td><span class="tag ${stCls(c.status)}">${stLbl(c.status)}</span></td>
      <td style="font-family:'DM Mono',monospace;color:#00ff88">${people.toLocaleString('pt-BR')}</td>
      <td style="font-family:'DM Mono',monospace">${attn}${attn!=='—'?'s':''}</td>
      <td>${moodIcon} ${rows.length ? mPct+'%' : '—'}</td>
      <td style="font-family:'DM Mono',monospace;color:var(--muted)">${fDate(c.created_at)}</td>
    </tr>`;
  }).join('');

  tableEl.innerHTML = `
    <table class="dt">
      <thead><tr><th>Campanha</th><th>Status</th><th>Pessoas</th><th>Atenção</th><th>Humor</th><th>Criada em</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

