    document.getElementById('ai-text').textContent = 'Verificando conteúdo antes de prosseguir...';
    document.getElementById('btn-create').disabled = true;
    document.getElementById('btn-create').innerHTML = '<div class="spin"></div> Verificando...';

    // Saldo na tela
    // Busca saldo atualizado ao abrir aba de criação
  const { data: walletRefresh } = await sb.from('wallets').select('credits,balance_brl').eq('user_id', ME.id).maybeSingle();
  if (walletRefresh) { WALL = { ...WALL, ...walletRefresh }; }
  if (WALL) {
    document.getElementById('saldo-atual').textContent = `${WALL.credits} créditos`;
    // Avisa visualmente se saldo insuficiente
