    setPipelineStep('kling','active',5);
    document.getElementById('pipeline-eta').textContent = '⏱️ WAN 2.6 gerando vídeo 3D (15s)... (~2-4 minutos)';
    btn.innerHTML = '<div class="spin"></div> Kling gerando...';

    console.log('🎬 Chamando Kling — campaign_id:', camp.id, 'token:', token?.slice(0,20));
    if (!camp?.id) throw new Error('campaign_id não encontrado. Tente novamente.');

    const klingRes = await fetch(`${SUPABASE_FUNCTIONS_URL}/ai-generate-video`, {
      method: 'POST',
      headers: { 
        'Authorization': `Bearer ${token}`,
        'Content-Type': 'application/json',
        'apikey': SUPABASE_KEY,
      },
      body: JSON.stringify({ campaign_id: camp.id }),
    });
    console.log('🎬 Kling response status:', klingRes.status);
    const klingData = await klingRes.json();
    console.log('🎬 Kling response data:', JSON.stringify(klingData));
    if (!klingData.success) throw new Error('Kling falhou: ' + (klingData.error || JSON.stringify(klingData)));

    const videoUrl = await pollStep('kling', token, camp.id, 'video', 600); // 10 min máximo
    setPipelineStep('kling','done',100);
    notif('Vídeo 3D gerado!','🎬');

    // Buscar vídeo final
    const { data: finalCamp } = await sb.from('campaigns').select('video_url').eq('id', camp.id).single();
    const finalVideoUrl = finalCamp?.video_url || videoUrl;

    document.getElementById('pipeline-eta').textContent = '✅ Pipeline concluído!';
    if (finalVideoUrl) {
      const rvEl = document.getElementById('result-video');
      rvEl.src = finalVideoUrl;
      rvEl.style.display = 'block';
      rvEl.load();
      document.getElementById('video-result').style.display = 'block';
    }

    const { data: newWallet } = await sb.from('wallets').select('*').eq('user_id',ME.id).maybeSingle();
    if (newWallet) { WALL = newWallet; document.getElementById('saldo-atual').textContent = `${WALL.credits} créditos`; }

    notif(`🚀 Vídeo 3D "${name}" pronto!`,'🎉');
    // Auto-switch to Minhas Campanhas to show the video
    setTimeout(() => {
      const galBtn = document.querySelector('#tabs-creative .tab:nth-child(2)');
      if (galBtn) { crtab(galBtn, 'cr-gallery'); loadCampaigns(); resumePollingIfNeeded(); }
    }, 1500);
    document.getElementById('c-name').value = '';
    clearImage();

  } catch(e) {
    console.error('Pipeline error:', e);
    // Mostra erro visível na UI
    document.getElementById('pipeline-eta').textContent = '❌ Erro: ' + e.message;
    const pStatus = document.getElementById('pipeline-status');
    if (pStatus) pStatus.style.borderColor = '#ff4d6d';
    const isTimeout = e.message.includes('Timeout') || e.message.includes('timeout');
    if (isTimeout) {
      notif('Vídeo ainda sendo processado. Verifique "Minhas Campanhas" em alguns minutos.','⏱️');
      document.getElementById('pipeline-eta').textContent = '⏱️ Processando em background... verifique Minhas Campanhas.';
