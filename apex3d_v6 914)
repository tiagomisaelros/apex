async function actDevice(id, status) {
  const upd = { status };
  if (status==='active') { upd.approved_at=new Date().toISOString(); upd.approved_by=ME.id; }
  // Busca dados da tela antes de atualizar
  const { data: dev } = await sb.from('devices').select('name, city, state, price_per_hour, owner_id').eq('id', id).single();
  const { error } = await sb.from('devices').update(upd).eq('id', id);
  if (!error) {
    notif(status==='active' ? 'Tela aprovada e ativa no marketplace!' : 'Tela rejeitada', status==='active' ? '✅' : '❌');
    // Notifica dono da tela se aprovada
    if (status === 'active' && dev?.owner_id) {
      sendNotification('screen_approved', dev.owner_id, {
        screen_name: dev.name,
        city: dev.city,
        state: dev.state,
        price: Number(dev.price_per_hour || 0).toFixed(2),
      });
    }
    loadAdmin();
  }
}

