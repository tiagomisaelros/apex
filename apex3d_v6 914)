// ── ENTERPRISE: MEMBROS ───────────────────────────────────────────────────
async function loadEntMembers() {
  if (!ENT_NETWORK) return;
  const list = document.getElementById('ent-members-list');
  list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--dim)"><div class="spin" style="margin:0 auto 12px"></div></div>';

  const { data: members } = await sb.from('enterprise_members')
    .select('*, profiles(full_name, email, role)')
    .eq('network_id', ENT_NETWORK.id)
    .order('created_at');

  if (!members?.length) {
    list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--dim)"><div style="font-size:32px;margin-bottom:8px">👥</div>Nenhum membro ainda. Convide alguém!</div>';
    return;
  }

  const roleLabel = { enterprise_admin:'🏢 Admin', enterprise_user:'👤 Usuário', screen_owner:'📺 Tela', advertiser:'🧑‍💼 Anunciante' };
  const statusColor = { active:'var(--green)', pending:'#ffd166', inactive:'var(--dim)' };

  list.innerHTML = members.map(m => `
    <div style="display:flex;align-items:center;justify-content:space-between;padding:12px;border:1px solid var(--border);border-radius:10px;margin-bottom:8px">
      <div style="display:flex;align-items:center;gap:10px">
        <div style="width:36px;height:36px;border-radius:50%;background:var(--accent)22;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:var(--accent)">${(m.profiles?.full_name||m.profiles?.email||'?')[0].toUpperCase()}</div>
        <div>
          <div style="font-size:13px;font-weight:600;color:var(--text)">${m.profiles?.full_name || m.profiles?.email || 'Usuário'}</div>
          <div style="font-size:11px;color:var(--dim)">${m.profiles?.email || ''}</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:8px">
        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:var(--surface2);color:var(--muted)">${roleLabel[m.role]||m.role}</span>
        <span style="font-size:10px;color:${statusColor[m.status]||'var(--dim)'}">● ${m.status}</span>
        ${m.user_id !== ENT_NETWORK.owner_id ? `<button onclick="removeMember('${m.id}','${(m.profiles?.full_name||'este membro').replace(/'/g,"\\'")}') " style="padding:3px 8px;background:rgba(255,77,109,.1);border:1px solid rgba(255,77,109,.3);color:#ff4d6d;border-radius:6px;font-size:10px;cursor:pointer">Remover</button>` : '<span style="font-size:10px;color:var(--dim)">👑 Owner</span>'}
      </div>
    </div>`).join('');
}

function openInviteMemberModal() {
  document.getElementById('inv-email').value = '';
  document.getElementById('inv-err').classList.remove('show');
  document.getElementById('inv-ok').classList.remove('show');
  openModal('m-invite-member');
}

async function doInviteMember() {
  if (!ENT_NETWORK) return;
  const email = document.getElementById('inv-email').value.trim();
  const role  = document.getElementById('inv-role').value;
  const btn   = document.getElementById('btn-invite');
  const err   = document.getElementById('inv-err');
  const ok    = document.getElementById('inv-ok');

  if (!email) { showErr(err, 'Digite o email'); return; }

  btn.disabled = true; btn.innerHTML = '<div class="spin"></div> Buscando usuário...';
  err.classList.remove('show');

  try {
    // Find user by email
    const { data: profile } = await sb.from('profiles').select('id, full_name, email').eq('email', email).maybeSingle();
    if (!profile) throw new Error('Usuário não encontrado. Peça para ele se cadastrar primeiro.');

    // Check if already member
    const { data: existing } = await sb.from('enterprise_members').select('id').eq('network_id', ENT_NETWORK.id).eq('user_id', profile.id).maybeSingle();
    if (existing) throw new Error('Este usuário já é membro da rede.');

    // Add member
    const { error: memErr } = await sb.from('enterprise_members').insert({
      network_id: ENT_NETWORK.id, user_id: profile.id, role, status: 'active',
      invited_by: ME.id
    });
    if (memErr) throw new Error(memErr.message);

    // Update profile role
    await sb.from('profiles').update({ role, network_id: ENT_NETWORK.id }).eq('id', profile.id);

    ok.textContent = `✅ ${profile.full_name || email} adicionado como ${role === 'enterprise_admin' ? 'Admin' : 'Usuário'}!`;
    ok.classList.add('show');
    setTimeout(() => { closeModal('m-invite-member'); loadEntMembers(); }, 1500);
  } catch(e) {
    showErr(err, e.message);
  } finally {
    btn.disabled = false; btn.innerHTML = 'Enviar Convite';
  }
}

async function removeMember(memberId, memberName) {
  if (!confirm(`Remover ${memberName} da rede?`)) return;
  const { error } = await sb.from('enterprise_members').delete().eq('id', memberId);
  if (error) { notif('Erro: ' + error.message, '❌'); return; }
  notif(`${memberName} removido da rede`, '✅');
  loadEntMembers();
}

// ── ENTERPRISE: APROVAÇÕES ───────────────────────────────────────────────
async function loadEntApprovals() {
  if (!ENT_NETWORK) return;
  const list = document.getElementById('ent-approvals-full');
  list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--dim)"><div class="spin" style="margin:0 auto 12px"></div></div>';

  const { data: approvals } = await sb.from('enterprise_approvals')
    .select('*, campaigns(name, video_url, original_image_url, physics_preset), profiles!requested_by(full_name, email)')
    .eq('network_id', ENT_NETWORK.id)
    .order('created_at', { ascending: false });

  if (!approvals?.length) {
    list.innerHTML = '<div style="text-align:center;padding:40px;color:var(--dim)"><div style="font-size:32px;margin-bottom:8px">✅</div>Nenhuma aprovação pendente</div>';
    return;
  }

  const statusColor = { pending:'#ffd166', approved:'var(--green)', rejected:'#ff4d6d' };
  const statusLabel = { pending:'⏳ Pendente', approved:'✅ Aprovado', rejected:'❌ Reprovado' };

  list.innerHTML = approvals.map(a => `
    <div style="padding:16px;border:1px solid ${a.status==='pending'?'rgba(255,209,102,.3)':'var(--border)'};border-radius:12px;margin-bottom:12px;background:${a.status==='pending'?'rgba(255,209,102,.04)':'transparent'}">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px">
        <div>
          <div style="font-size:14px;font-weight:700;color:var(--text)">${a.campaigns?.name || 'Campanha'}</div>
          <div style="font-size:11px;color:var(--dim)">por ${a.profiles?.full_name || a.profiles?.email} · ${new Date(a.created_at).toLocaleDateString('pt-BR')}</div>
        </div>
        <span style="font-size:11px;padding:3px 10px;border-radius:20px;background:${statusColor[a.status]}22;color:${statusColor[a.status]};border:1px solid ${statusColor[a.status]}44">${statusLabel[a.status]}</span>
      </div>
      ${a.campaigns?.video_url ? `<video src="${a.campaigns.video_url}" controls muted style="width:100%;border-radius:8px;max-height:160px;margin-bottom:10px"></video>` : ''}
      ${a.status === 'pending' ? `
        <div style="display:flex;gap:8px">
          <button onclick="approveEntCampaign('${a.id}','${a.campaigns?.name||''}',true)" class="btn btn-p btn-sm" style="flex:1">✅ Aprovar</button>
          <button onclick="approveEntCampaign('${a.id}','${a.campaigns?.name||''}',false)" class="btn btn-sm" style="flex:1;background:rgba(255,77,109,.1);color:#ff4d6d;border:1px solid rgba(255,77,109,.3)">❌ Reprovar</button>
        </div>` : ''}
    </div>`).join('');
}

async function approveEntCampaign(approvalId, campName, approve) {
  const status = approve ? 'approved' : 'rejected';
  const { error } = await sb.from('enterprise_approvals').update({ status, reviewed_by: ME.id, reviewed_at: new Date().toISOString() }).eq('id', approvalId);
  if (error) { notif('Erro: ' + error.message, '❌'); return; }

  // Also update campaign status
  if (approve) {
    const { data: approval } = await sb.from('enterprise_approvals').select('campaign_id').eq('id', approvalId).single();
    if (approval) await sb.from('campaigns').update({ status: 'approved' }).eq('id', approval.campaign_id);
  }

  notif(`Campanha "${campName}" ${approve ? 'aprovada' : 'reprovada'}!`, approve ? '✅' : '❌');
  loadEntApprovals();
  loadEnterprise(); // refresh pending count
}

// ── ENTERPRISE: RELATÓRIO ─────────────────────────────────────────────────
async function loadEntReport() {
  if (!ENT_NETWORK) return;
  const el = document.getElementById('ent-report-content');
  el.innerHTML = '<div style="text-align:center;padding:40px;color:var(--dim)"><div class="spin" style="margin:0 auto 12px"></div>Calculando relatório...</div>';

  const { data: repMembers } = await sb.from('enterprise_members')
    .select('user_id').eq('network_id', ENT_NETWORK.id).eq('status', 'active');
  const repOwnerSet = new Set((repMembers || []).map(m => m.user_id));
  if (ENT_NETWORK.owner_id) repOwnerSet.add(ENT_NETWORK.owner_id);
  const repMemberIds = [...repOwnerSet];

  const [screenRes, campRes, branchRes, repasseRes] = await Promise.all([
    repMemberIds.length ? sb.from('devices').select('id,name,last_heartbeat,status').in('owner_id', repMemberIds) : Promise.resolve({ data: [] }),
    repMemberIds.length ? sb.from('campaigns').select('id,name,status,total_views,created_at').in('user_id', repMemberIds) : Promise.resolve({ data: [] }),
    sb.from('enterprise_branches').select('id,name,city,state').eq('network_id', ENT_NETWORK.id),
    repMemberIds.length ? sb.from('revenue_splits').select('owner_amount,status').in('owner_id', repMemberIds) : Promise.resolve({ data: [] }),
  ]);

  const screens   = screenRes.data || [];
  const camps     = campRes.data   || [];
  const branches  = branchRes.data || [];
  const repasses  = repasseRes.data|| [];

  const totalViews   = camps.reduce((a,c) => a+(c.total_views||0), 0);
  const totalRepasse = repasses.filter(r=>r.status==='paid').reduce((a,r) => a+parseFloat(r.owner_amount||0), 0);
  const pendRepasse  = repasses.filter(r=>r.status==='pending').reduce((a,r) => a+parseFloat(r.owner_amount||0), 0);
  const now = Date.now();
  const onlineScreens = screens.filter(s => s.last_heartbeat && (now - new Date(s.last_heartbeat).getTime()) < 90000).length;

  el.innerHTML = `
    <div class="sg" style="margin-bottom:20px">
      <div class="sc" style="--al:#3a86ff"><div class="sl">🏬 Filiais</div><div class="sv">${branches.length}</div></div>
      <div class="sc" style="--al:#ff6b2b"><div class="sl">📺 Telas online</div><div class="sv">${onlineScreens}/${screens.length}</div></div>
      <div class="sc" style="--al:#00ff88"><div class="sl">👁 Total views</div><div class="sv">${totalViews.toLocaleString('pt-BR')}</div></div>
      <div class="sc" style="--al:#ffd166"><div class="sl">💰 Repasse pago</div><div class="sv">R$${totalRepasse.toFixed(2)}</div></div>
    </div>
    <div class="g2">
      <div class="card">
        <div class="st" style="margin-bottom:12px">📺 Status das Telas</div>
        ${screens.map(s => {
          const online = s.last_heartbeat && (now - new Date(s.last_heartbeat).getTime()) < 90000;
          return `<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px">
            <span style="color:var(--text)">${s.name}</span>
            <span style="color:${s.status==='maintenance'?'#ffc107':online?'var(--green)':'#ff4d6d'}">${s.status==='maintenance'?'⚙️ Manutenção':online?'● Online':'● Offline'}</span>
          </div>`;
        }).join('') || '<div style="color:var(--dim);font-size:13px;padding:12px 0">Nenhuma tela</div>'}
      </div>
      <div class="card">
        <div class="st" style="margin-bottom:12px">🎬 Campanhas Recentes</div>
        ${camps.slice(0,6).map(c => `
          <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);font-size:12px">
            <span style="color:var(--text)">${c.name}</span>
            <span style="color:var(--dim)">${(c.total_views||0).toLocaleString('pt-BR')} views</span>
          </div>`).join('') || '<div style="color:var(--dim);font-size:13px;padding:12px 0">Nenhuma campanha</div>'}
        <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);display:flex;justify-content:space-between;font-size:12px">
          <span style="color:var(--muted)">💰 Repasse pendente</span>
          <span style="color:#ffd166;font-weight:700">R$${pendRepasse.toFixed(2)}</span>
        </div>
      </div>
    </div>`;
  window._entReportData = { screens, camps, branches, repasses, network: ENT_NETWORK };
}

async function exportEntReport() {
  if (!window._entReportData) { await loadEntReport(); }
  const { screens, camps, branches, repasses, network } = window._entReportData;
  const now = Date.now();
  const onlineScreens = screens.filter(s => s.last_heartbeat && (now - new Date(s.last_heartbeat).getTime()) < 90000).length;
  const totalViews    = camps.reduce((a,c) => a+(c.total_views||0), 0);
  const totalRepasse  = repasses.filter(r=>r.status==='paid').reduce((a,r) => a+parseFloat(r.owner_amount||0), 0);

  const rows = [
    ['Rede', network.name],
    ['Plano', network.plan],
    ['Filiais', branches.length],
    ['Telas online', onlineScreens + '/' + screens.length],
    ['Total campanhas', camps.length],
    ['Total views', totalViews],
    ['Repasse pago (R$)', totalRepasse.toFixed(2)],
    [''],
    ['--- TELAS ---'],
    ['Nome', 'Status', 'Último heartbeat'],
    ...screens.map(s => [s.name, s.status, s.last_heartbeat ? new Date(s.last_heartbeat).toLocaleString('pt-BR') : 'N/A']),
    [''],
    ['--- CAMPANHAS ---'],
    ['Nome', 'Status', 'Views', 'Criada em'],
    ...camps.map(c => [c.name, c.status, c.total_views||0, new Date(c.created_at).toLocaleDateString('pt-BR')]),
  ];

  const csv = rows.map(r => r.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = `relatorio_${network.name.replace(/\s+/g,'_')}_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  notif('Relatório exportado!', '📊');
}

