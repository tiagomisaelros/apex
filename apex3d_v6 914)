async function initGradeConfigDevices() {
  const sel = document.getElementById('cfg-device-select');
  if (!sel) return;

  sel.innerHTML = '<option value="">Carregando telas...</option>';

  try {
    let q = sb.from('devices').select('id, name, screen_id');
    if (PROF?.role !== 'super_admin') q = q.eq('owner_id', ME.id);
    const { data: devs, error } = await q.order('name');

    if (error) throw error;

    if (!devs?.length) {
      sel.innerHTML = '<option value="">Nenhuma tela cadastrada</option>';
      document.getElementById('adm-content-list').innerHTML =
        '<div style="text-align:center;padding:30px;color:var(--dim)">Nenhuma tela cadastrada ainda.</div>';
      return;
    }
    sel.innerHTML = devs.map(d =>
      `<option value="${d.id}">${d.name || d.id}</option>`
    ).join('');

    loadGradeConfig();
  } catch(e) {
    console.error('initGradeConfigDevices erro:', e);
    sel.innerHTML = '<option value="">Erro ao carregar telas</option>';
    notif('Erro ao carregar telas: ' + e.message, '❌');
  }
}

async function loadGradeConfig() {
  const deviceId = document.getElementById('cfg-device-select')?.value;
  if (!deviceId) return;

  const { data: cfg } = await sb.from('screen_schedule_config')
    .select('advertiser_slots, admin_slots, news_slots')
    .eq('device_id', deviceId)
    .maybeSingle();

  const adv  = cfg?.advertiser_slots ?? 40;
  const inst = cfg?.admin_slots      ?? 10;
  const news = cfg?.news_slots       ?? 5;

  document.getElementById('cfg-adv').value  = adv;
  document.getElementById('cfg-inst').value = inst;
  document.getElementById('cfg-news').value = news;

  updateGradeSliders();
}

function updateGradeSliders() {
  const adv  = parseInt(document.getElementById('cfg-adv')?.value  || 40);
  const inst = parseInt(document.getElementById('cfg-inst')?.value || 10);
  const news = parseInt(document.getElementById('cfg-news')?.value || 5);
  const total = adv + inst + news;

  // Validação: total não pode passar de 60
  document.getElementById('cfg-adv-val').textContent  = adv;
  document.getElementById('cfg-inst-val').textContent = inst;
  document.getElementById('cfg-news-val').textContent = news;

  const totalEl = document.getElementById('cfg-total');
  if (totalEl) {
    totalEl.textContent = total;
    totalEl.style.color = total > 60 ? '#ff4444' : total === 60 ? '#4ade80' : 'var(--text)';
  }

  // Barra visual do ciclo
  const bar = document.getElementById('cfg-bar');
  if (bar) {
    const blocks = [];
    // Distribui proporcionalmente em 60 blocos visuais
    const scale = Math.min(60, total);
    const advW  = Math.round(adv  / total * scale);
    const instW = Math.round(inst / total * scale);
    const newsW = scale - advW - instW;

    const total3 = advW + instW + newsW || 1;
    bar.innerHTML =
      `<div style="width:${Math.round(advW/total3*100)}%;background:var(--accent);height:100%"></div>` +
      `<div style="width:${Math.round(instW/total3*100)}%;background:#4ade80;height:100%"></div>` +
      `<div style="width:${Math.round(newsW/total3*100)}%;background:#3a86ff;height:100%"></div>`;
  }
}

async function saveGradeConfig() {
  const deviceId = document.getElementById('cfg-device-select')?.value;
  if (!deviceId) { notif('Selecione uma tela','⚠️'); return; }

  const adv  = parseInt(document.getElementById('cfg-adv').value);
  const inst = parseInt(document.getElementById('cfg-inst').value);
  const news = parseInt(document.getElementById('cfg-news').value);
  const total = adv + inst + news;

  if (total > 60) { notif('Total não pode ultrapassar 60 posições','⚠️'); return; }
  if (adv < 5)    { notif('Mínimo de 5 vagas para anunciantes','⚠️'); return; }
  if (inst < 5)   { notif('Mínimo de 5 vagas institucionais','⚠️'); return; }

  const { error } = await sb.from('screen_schedule_config')
    .upsert({
      device_id:        deviceId,
      advertiser_slots: adv,
      admin_slots:      inst,
      news_slots:       news,
      max_advertisers:  adv,
      slot_duration_sec: 15,
    }, { onConflict: 'device_id' });

  if (error) { notif('Erro: ' + error.message, '❌'); return; }

  notif(`✅ Grade salva: ${adv} anunciantes · ${inst} institucionais · ${news} notícias`, '📺');

  const tabInst = document.getElementById('gc-tab-engagement');
  const tabNews = document.getElementById('gc-tab-news');
  if (tabInst) tabInst.textContent = `🎬 Institucional (${inst} vagas)`;
  if (tabNews) tabNews.textContent = `📰 Notícias (${news} vagas)`;
}


