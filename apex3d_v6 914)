let _screensToken = 0;
let _screensCache = null;       // cache dos resultados
let _screensCacheKey = '';      // chave do cache (venue atual)

let _loadingScreens = false;
async function loadScreens(forceReload = false) {
  const search = document.getElementById('mk-search')?.value.trim().toLowerCase() || '';
  const venue  = document.getElementById('mk-venue')?.value || '';
  const grid   = document.getElementById('screens-grid');
  if (!grid) return;

  const cacheKey = venue + '|' + search;
  // Usa cache se disponível e não forçando reload
  if (!forceReload && _screensCache && _screensCacheKey === cacheKey) {
    renderScreensGrid(_screensCache, search);
    return;
  }

  // Evita chamadas simultâneas
  if (_loadingScreens) return;
  _loadingScreens = true;

  const _t = ++_screensToken;
  grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--dim)"><div class="spin" style="margin:0 auto 12px"></div>Carregando telas...</div>';

  let q = sb.from('screens').select('*').eq('status','active');
  if (venue) q = q.eq('screen_type', venue);

  // Timeout de 10s para evitar loop infinito
  const timeoutPromise = new Promise((_, rej) => setTimeout(() => rej(new Error('Timeout ao carregar telas (10s)')), 10000));
  const queryPromise = q.order('daily_traffic', { ascending: false }).limit(30);
  let screens, screensErr;
  try {
    const result = await Promise.race([queryPromise, timeoutPromise]);
    screens = result.data;
    screensErr = result.error;
  } catch(timeoutErr) {
    _loadingScreens = false;
    grid.innerHTML = '<div class="empty" style="grid-column:1/-1"><div class="empty-i">⏱️</div><div class="empty-t">Tempo esgotado</div><div class="empty-s">Tente novamente clicando em Buscar</div><button class="btn btn-p btn-sm" style="margin-top:12px" onclick="_screensCache=null;loadScreens(true)">🔄 Tentar novamente</button></div>';
    return;
  }
  console.log('loadScreens result:', screens?.length, 'screens | error:', screensErr?.message);
  if (_t !== _screensToken) { _loadingScreens = false; return; }
  // Guarda no cache
  if (!screensErr && screens) { _screensCache = screens; _screensCacheKey = cacheKey; }

  if (screensErr) {
    _loadingScreens = false;
    grid.innerHTML = '<div class="empty" style="grid-column:1/-1"><div class="empty-i">⚠️</div><div class="empty-t">Erro ao carregar telas</div><div class="empty-s">' + screensErr.message + '</div></div>';
    return;
  }

  if (!screens || !screens.length) {
    grid.innerHTML = '<div class="empty" style="grid-column:1/-1"><div class="empty-i">📺</div><div class="empty-t">Nenhuma tela disponível</div><div class="empty-s">Cadastre a primeira tela no botão acima</div></div>';
    return;
  }

  renderScreensGrid(screens, search);
  _loadingScreens = false;
}

